<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="controllers.HealthRecordController"
      spacing="20" VBox.vgrow="ALWAYS">
    <padding>
        <Insets top="0" right="0" bottom="0" left="0"/>
    </padding>


    <VBox styleClass="mgmt-form-card" spacing="0">


        <HBox styleClass="mgmt-form-card-header" alignment="CENTER_LEFT" spacing="12">
            <VBox spacing="3">
                <Label text="Ajouter / Modifier un Dossier de Santé" styleClass="mgmt-form-title"/>
                <Label text="Aucun champ n'est obligatoire sauf la date" styleClass="mgmt-form-subtitle"/>
            </VBox>
        </HBox>


        <VBox styleClass="mgmt-form-body" spacing="0">
            <GridPane hgap="16" vgap="11">

                <Label text="Animal" styleClass="mgmt-form-label" GridPane.columnIndex="0" GridPane.rowIndex="0" GridPane.valignment="CENTER"/>
                <ComboBox fx:id="animalCombo" promptText="Choisir un animal" styleClass="mgmt-combo"
                          GridPane.columnIndex="1" GridPane.rowIndex="0" GridPane.columnSpan="3"
                          maxWidth="Infinity" onAction="#onAnimalSelected"/>

                <Label text="Date du Dossier" styleClass="mgmt-form-label" GridPane.columnIndex="0" GridPane.rowIndex="1" GridPane.valignment="CENTER"/>
                <DatePicker fx:id="recordDatePicker" styleClass="mgmt-datepicker" GridPane.columnIndex="1" GridPane.rowIndex="1" prefWidth="160"/>

                <Label text="Poids (kg)" styleClass="mgmt-form-label" GridPane.columnIndex="2" GridPane.rowIndex="1" GridPane.valignment="CENTER"/>
                <TextField fx:id="weightField" promptText="" styleClass="mgmt-input" GridPane.columnIndex="3" GridPane.rowIndex="1" prefWidth="140"/>

                <Label text="Appétit" styleClass="mgmt-form-label" GridPane.columnIndex="0" GridPane.rowIndex="2" GridPane.valignment="CENTER"/>
                <ComboBox fx:id="appetiteCombo" promptText="Sélectionner" styleClass="mgmt-combo" GridPane.columnIndex="1" GridPane.rowIndex="2" prefWidth="160"/>

                <Label text="Condition" styleClass="mgmt-form-label" GridPane.columnIndex="2" GridPane.rowIndex="2" GridPane.valignment="CENTER"/>
                <ComboBox fx:id="conditionCombo" promptText="Sélectionner" styleClass="mgmt-combo" GridPane.columnIndex="3" GridPane.rowIndex="2" prefWidth="160"/>


                <Label fx:id="productionLabel" text="Production" styleClass="mgmt-form-label" GridPane.columnIndex="0" GridPane.rowIndex="3" GridPane.valignment="CENTER"/>
                <TextField fx:id="productionField" promptText="" styleClass="mgmt-input" GridPane.columnIndex="1" GridPane.rowIndex="3" prefWidth="140"/>

                <Label text="Notes" styleClass="mgmt-form-label" GridPane.columnIndex="2" GridPane.rowIndex="3" GridPane.valignment="CENTER"/>
                <TextField fx:id="notesField" promptText="" styleClass="mgmt-input" GridPane.columnIndex="3" GridPane.rowIndex="3" prefWidth="200"/>


                <HBox spacing="10" alignment="CENTER_LEFT" GridPane.columnIndex="0" GridPane.rowIndex="4" GridPane.columnSpan="4">
                    <padding><Insets top="6"/></padding>
                    <Button text="Ajouter" onAction="#onAddRecord" styleClass="mgmt-btn-primary"/>
                    <Button text="Modifier" fx:id="updateBtn" onAction="#onUpdateRecord" styleClass="mgmt-btn-ghost" disable="true"/>
                    <Button text="Supprimer" fx:id="deleteBtn" onAction="#onDeleteRecord" styleClass="mgmt-btn-danger" disable="true"/>
                </HBox>
            </GridPane>
        </VBox>
    </VBox>


    <VBox fx:id="visitCard" styleClass="mgmt-form-card" spacing="0">
        <HBox styleClass="mgmt-form-card-header" alignment="CENTER_LEFT" spacing="12">
            <VBox spacing="3">
                <Label text="Visite par Emplacement" styleClass="mgmt-form-title"/>
                <Label text="Parcourez les animaux d'un emplacement un par un et enregistrez leurs dossiers" styleClass="mgmt-form-subtitle"/>
            </VBox>
        </HBox>
        <VBox styleClass="mgmt-form-body" spacing="12">

            <HBox fx:id="visitSetupRow" spacing="12" alignment="CENTER_LEFT">
                <Label text="Emplacement :" styleClass="mgmt-form-label"/>
                <ComboBox fx:id="visitLocationCombo" promptText="Choisir un emplacement..."
                          styleClass="mgmt-combo" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                <Button text="Démarrer la Visite" onAction="#onStartVisit" styleClass="mgmt-btn-primary"/>
            </HBox>

            <VBox fx:id="visitWizardBox" spacing="12" visible="false" managed="false">
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <Label fx:id="visitProgressLabel" text="" styleClass="mgmt-form-title"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="Terminer" onAction="#onEndVisit" styleClass="mgmt-btn-ghost"/>
                </HBox>
                <Label fx:id="visitAnimalInfoLabel" text="" styleClass="mgmt-form-subtitle"/>
                <GridPane hgap="16" vgap="11">
                    <Label text="Date" styleClass="mgmt-form-label" GridPane.columnIndex="0" GridPane.rowIndex="0" GridPane.valignment="CENTER"/>
                    <DatePicker fx:id="visitDatePicker" styleClass="mgmt-datepicker" GridPane.columnIndex="1" GridPane.rowIndex="0" prefWidth="160"/>

                    <Label text="Poids (kg)" styleClass="mgmt-form-label" GridPane.columnIndex="2" GridPane.rowIndex="0" GridPane.valignment="CENTER"/>
                    <TextField fx:id="visitWeightField" promptText="" styleClass="mgmt-input" GridPane.columnIndex="3" GridPane.rowIndex="0" prefWidth="140"/>

                    <Label text="Appétit" styleClass="mgmt-form-label" GridPane.columnIndex="0" GridPane.rowIndex="1" GridPane.valignment="CENTER"/>
                    <ComboBox fx:id="visitAppetiteCombo" promptText="Sélectionner" styleClass="mgmt-combo" GridPane.columnIndex="1" GridPane.rowIndex="1" prefWidth="160"/>

                    <Label text="Condition" styleClass="mgmt-form-label" GridPane.columnIndex="2" GridPane.rowIndex="1" GridPane.valignment="CENTER"/>
                    <ComboBox fx:id="visitConditionCombo" promptText="Sélectionner" styleClass="mgmt-combo" GridPane.columnIndex="3" GridPane.rowIndex="1" prefWidth="160"/>

                    <Label fx:id="visitProductionLabel" text="Production" styleClass="mgmt-form-label" GridPane.columnIndex="0" GridPane.rowIndex="2" GridPane.valignment="CENTER"/>
                    <TextField fx:id="visitProductionField" promptText="" styleClass="mgmt-input" GridPane.columnIndex="1" GridPane.rowIndex="2" prefWidth="140"/>

                    <Label text="Notes" styleClass="mgmt-form-label" GridPane.columnIndex="2" GridPane.rowIndex="2" GridPane.valignment="CENTER"/>
                    <TextField fx:id="visitNotesField" promptText="" styleClass="mgmt-input" GridPane.columnIndex="3" GridPane.rowIndex="2" prefWidth="200"/>

                    <HBox spacing="10" alignment="CENTER_LEFT" GridPane.columnIndex="0" GridPane.rowIndex="3" GridPane.columnSpan="4">
                        <padding><Insets top="6"/></padding>
                        <Button text="Sauvegarder &amp; Suivant" onAction="#onVisitSaveAndNext" styleClass="mgmt-btn-primary"/>
                        <Button text="Passer" onAction="#onVisitSkip" styleClass="mgmt-btn-ghost"/>
                    </HBox>
                </GridPane>
            </VBox>

            <Label fx:id="visitStatusLabel" text="" styleClass="mgmt-form-subtitle" wrapText="true"/>

        </VBox>
    </VBox>


    <VBox styleClass="mgmt-table-card" VBox.vgrow="ALWAYS" spacing="12">
        <HBox alignment="CENTER_LEFT" spacing="12">
            <Label fx:id="recordsTitleLabel" text="Dossiers de Santé de l'Animal Sélectionné" styleClass="mgmt-table-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <ComboBox fx:id="searchFieldCombo" promptText="Rechercher par" styleClass="mgmt-combo" prefWidth="135"/>
            <TextField fx:id="searchField" promptText="Rechercher..." styleClass="mgmt-input" prefWidth="190"/>
            <Button text="Actualiser" onAction="#onRefreshRecords" styleClass="mgmt-btn-ghost"/>
        </HBox>
        <ScrollPane fitToWidth="true" styleClass="mgmt-scroll" VBox.vgrow="ALWAYS" minHeight="200">
            <VBox fx:id="recordTableContainer" styleClass="mgmt-table-container"/>
        </ScrollPane>
    </VBox>
</VBox>
