<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="controllers.HealthRecordController"
      spacing="20" VBox.vgrow="ALWAYS">
    <padding>
        <Insets top="0" right="0" bottom="0" left="0"/>
    </padding>


    <VBox styleClass="mgmt-form-card" spacing="0">


        <HBox styleClass="mgmt-form-card-header" alignment="CENTER_LEFT" spacing="12">
            <VBox spacing="3">
                <Label text="Add / Edit Health Record" styleClass="mgmt-form-title"/>
                <Label text="You can add or edit animal health records" styleClass="mgmt-form-subtitle"/>
            </VBox>
        </HBox>


        <VBox styleClass="mgmt-form-body" spacing="0">
            <GridPane hgap="16" vgap="11">

                <Label text="Animal" styleClass="mgmt-form-label" GridPane.columnIndex="0" GridPane.rowIndex="0" GridPane.valignment="CENTER"/>
                <ComboBox fx:id="animalCombo" promptText="Choose animal" styleClass="mgmt-combo"
                          GridPane.columnIndex="1" GridPane.rowIndex="0" GridPane.columnSpan="3"
                          maxWidth="Infinity" onAction="#onAnimalSelected"/>

                <Label text="Record Date" styleClass="mgmt-form-label" GridPane.columnIndex="0" GridPane.rowIndex="1" GridPane.valignment="CENTER"/>
                <DatePicker fx:id="recordDatePicker" styleClass="mgmt-datepicker" GridPane.columnIndex="1" GridPane.rowIndex="1" prefWidth="160"/>

                <Label text="Weight (kg)" styleClass="mgmt-form-label" GridPane.columnIndex="2" GridPane.rowIndex="1" GridPane.valignment="CENTER"/>
                <TextField fx:id="weightField" promptText="e.g. 250.0" styleClass="mgmt-input" GridPane.columnIndex="3" GridPane.rowIndex="1" prefWidth="140"/>

                <Label text="Appetite" styleClass="mgmt-form-label" GridPane.columnIndex="0" GridPane.rowIndex="2" GridPane.valignment="CENTER"/>
                <ComboBox fx:id="appetiteCombo" promptText="Select" styleClass="mgmt-combo" GridPane.columnIndex="1" GridPane.rowIndex="2" prefWidth="160"/>

                <Label text="Condition" styleClass="mgmt-form-label" GridPane.columnIndex="2" GridPane.rowIndex="2" GridPane.valignment="CENTER"/>
                <ComboBox fx:id="conditionCombo" promptText="Select" styleClass="mgmt-combo" GridPane.columnIndex="3" GridPane.rowIndex="2" prefWidth="160"/>


                <Label fx:id="productionLabel" text="Production" styleClass="mgmt-form-label" GridPane.columnIndex="0" GridPane.rowIndex="3" GridPane.valignment="CENTER"/>
                <TextField fx:id="productionField" promptText="value" styleClass="mgmt-input" GridPane.columnIndex="1" GridPane.rowIndex="3" prefWidth="140"/>

                <Label text="Notes" styleClass="mgmt-form-label" GridPane.columnIndex="2" GridPane.rowIndex="3" GridPane.valignment="CENTER"/>
                <TextField fx:id="notesField" promptText="Optional notes" styleClass="mgmt-input" GridPane.columnIndex="3" GridPane.rowIndex="3" prefWidth="200"/>


                <HBox spacing="10" alignment="CENTER_LEFT" GridPane.columnIndex="0" GridPane.rowIndex="4" GridPane.columnSpan="4">
                    <padding><Insets top="6"/></padding>
                    <Button text="Add Record" onAction="#onAddRecord" styleClass="mgmt-btn-primary"/>
                    <Button text="Update" fx:id="updateBtn" onAction="#onUpdateRecord" styleClass="mgmt-btn-ghost" disable="true"/>
                    <Button text="Delete" fx:id="deleteBtn" onAction="#onDeleteRecord" styleClass="mgmt-btn-danger" disable="true"/>
                </HBox>
            </GridPane>
        </VBox>
    </VBox>


    <VBox styleClass="mgmt-table-card" VBox.vgrow="ALWAYS" spacing="12">
        <HBox alignment="CENTER_LEFT" spacing="12">
            <Label fx:id="recordsTitleLabel" text="Health Records for Selected Animal" styleClass="mgmt-table-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <ComboBox fx:id="searchFieldCombo" promptText="Search by" styleClass="mgmt-combo" prefWidth="135"/>
            <TextField fx:id="searchField" promptText="Search..." styleClass="mgmt-input" prefWidth="190"/>
            <Button text="Refresh" onAction="#onRefreshRecords" styleClass="mgmt-btn-ghost"/>
        </HBox>
        <ScrollPane fitToWidth="true" styleClass="mgmt-scroll" VBox.vgrow="ALWAYS" minHeight="200">
            <VBox fx:id="recordTableContainer" styleClass="mgmt-table-container"/>
        </ScrollPane>
    </VBox>
</VBox>
