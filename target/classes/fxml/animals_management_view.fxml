<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" VBox.vgrow="ALWAYS" stylesheets="@/animals-management.css">
    <padding>
        <Insets top="24" right="32" bottom="24" left="32"/>
    </padding>
    <TabPane styleClass="mgmt-tab-pane" tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">
        <tabs>
            <Tab text="Animals" styleClass="mgmt-tab">
                <fx:include source="animal_view.fxml"/>
            </Tab>
            <Tab text="Options" styleClass="mgmt-tab">
                <fx:include source="options_view.fxml"/>
            </Tab>
            <Tab text="Health Records" styleClass="mgmt-tab">
                <fx:include source="health_record_view.fxml"/>
            </Tab>
        </tabs>
    </TabPane>
</VBox>
