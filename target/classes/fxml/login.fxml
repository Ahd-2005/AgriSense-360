<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.login"
            style="-fx-background-color: #e8f5e9;">

    <center>
        <VBox alignment="CENTER" spacing="25" style="-fx-padding: 50;">

            <Label text="🌱 AgriSense 360"
                   style="-fx-font-size: 48px; -fx-font-weight: bold; -fx-text-fill: #2e7d32;" />

            <Label text="Bienvenue! Connectez-vous à votre compte"
                   style="-fx-font-size: 18px; -fx-text-fill: #546e7a;" />

            <VBox spacing="15" style="-fx-max-width: 400; -fx-alignment: center;">

                <!-- General Login Error -->
                <Label fx:id="loginError" visible="false"
                       style="-fx-text-fill: #d32f2f; -fx-font-size: 12px; -fx-font-weight: bold;"/>

                <!-- Email Field -->
                <VBox spacing="5">
                    <TextField fx:id="emailField"
                               promptText="Email"
                               style="-fx-pref-height: 45; -fx-font-size: 16px;
                                      -fx-background-radius: 10; -fx-border-radius: 10;" />
                    <Label fx:id="emailError" visible="false"
                           style="-fx-text-fill: #d32f2f; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                </VBox>

                <!-- Password Field -->
                <VBox spacing="5">
                    <PasswordField fx:id="passwordField"
                                   promptText="Mot de passe"
                                   style="-fx-pref-height: 45; -fx-font-size: 16px;
                                          -fx-background-radius: 10; -fx-border-radius: 10;" />
                    <Label fx:id="passwordError" visible="false"
                           style="-fx-text-fill: #d32f2f; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                </VBox>

                <!-- ✅ Mot de passe oublié → navigue vers ForgotPassword.fxml -->
                <Hyperlink text="Mot de passe oublié?"
                           onAction="#handleForgotPassword"
                           style="-fx-text-fill: #2e7d32; -fx-font-size: 14px;" />

                <Button fx:id="loginBtn"
                        text="Se connecter"
                        onAction="#handleLogin"
                        style="-fx-background-color: #4CAF50; -fx-text-fill: white;
                               -fx-padding: 15 50; -fx-font-size: 16px; -fx-font-weight: bold;
                               -fx-background-radius: 25; -fx-cursor: hand; -fx-pref-width: 400;" />

                <HBox alignment="CENTER" spacing="5">
                    <Label text="Vous n'avez pas de compte?"
                           style="-fx-font-size: 14px; -fx-text-fill: #546e7a;" />
                    <Hyperlink fx:id="signupLink"
                               text="Créer un compte"
                               onAction="#goToSignup"
                               style="-fx-text-fill: #2e7d32; -fx-font-size: 14px; -fx-font-weight: bold;" />
                </HBox>

                <!-- Séparateur -->
                <HBox alignment="CENTER" spacing="10">
                    <Separator HBox.hgrow="ALWAYS"/>
                    <Label text="OU"/>
                    <Separator HBox.hgrow="ALWAYS"/>
                </HBox>

                <!-- Bouton Google -->
                <Button fx:id="googleLoginBtn"
                        text="🔍  Se connecter avec Google"
                        onAction="#handleGoogleLogin"
                        maxWidth="Infinity"
                        prefHeight="45"
                        style="-fx-background-color: white;
                               -fx-border-color: #dadce0;
                               -fx-border-width: 1.5;
                               -fx-border-radius: 8;
                               -fx-background-radius: 8;
                               -fx-text-fill: #3c4043;
                               -fx-font-size: 14px;
                               -fx-cursor: hand;
                               -fx-pref-width: 400;" />
                <Button text="👤  Se connecter avec mon visage"
                        onAction="#handleFaceLogin"
                        maxWidth="Infinity"
                        style="-fx-background-color: #2e7d32; -fx-text-fill: white;
               -fx-font-size: 14px; -fx-font-weight: bold;
               -fx-pref-height: 45; -fx-background-radius: 8;
               -fx-cursor: hand;"/>

            </VBox>
        </VBox>
    </center>

</BorderPane>
