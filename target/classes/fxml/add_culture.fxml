<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="15" alignment="CENTER" xmlns:fx="http://javafx.com/fxml"
      fx:controller="controllers.CultureController"
      style="-fx-padding: 20; -fx-background-color: #f5f5f5;">

    <Label text="➕ Ajouter une Culture"
           style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

    <ComboBox fx:id="typeComboBox" promptText="Sélectionner le type de culture"
              style="-fx-font-size: 14px;" prefWidth="300"/>

    <ComboBox fx:id="nomComboBox" promptText="Sélectionner d'abord le type"
              disable="true" style="-fx-font-size: 14px;" prefWidth="300"/>

    <VBox spacing="5">
        <Label text="Date de plantation:" style="-fx-font-size: 12px;"/>
        <DatePicker fx:id="datePlantationPicker" prefWidth="300"/>
    </VBox>

    <VBox spacing="5">
        <Label text="Date de récolte:" style="-fx-font-size: 12px;"/>
        <DatePicker fx:id="dateRecoltePicker" prefWidth="300"/>
    </VBox>

    <ComboBox fx:id="etatComboBox" promptText="Sélectionner un état"
              style="-fx-font-size: 14px;" prefWidth="300"/>

    <ComboBox fx:id="parcelleComboBox" promptText="Sélectionner une parcelle libre"
              style="-fx-font-size: 14px;" prefWidth="300"/>

    <TextField fx:id="surfaceField" promptText="Surface de la culture en m² (nombre positif)"
               style="-fx-font-size: 14px;" prefWidth="300"/>

    <HBox spacing="10" alignment="CENTER">
        <Button text="✅ Ajouter" onAction="#handleAddCulture"
                style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 10 20;"/>

        <Button text="📋 Afficher Cultures" onAction="#goToList"
                style="-fx-background-color: #2196F3; -fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 10 20;"/>
    </HBox>

    <Label fx:id="messageLabel" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>

</VBox>