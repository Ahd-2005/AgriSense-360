<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.ParcelleController"
            prefHeight="700.0" prefWidth="1200.0"
            stylesheets="@../css/cards.css">

    <top>
        <VBox spacing="0">
            <!-- Top Bar with Purple Gradient -->
            <HBox alignment="CENTER_LEFT" spacing="15"
                  style="-fx-background-color: linear-gradient(to right, #7B1FA2, #9C27B0); -fx-padding: 20;">
                <Label text="🌍 Mes Parcelles"
                       style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                <Region HBox.hgrow="ALWAYS"/>

                <!-- Search Bar -->
                <TextField fx:id="searchField" promptText="🔍 Rechercher par nom..."
                           styleClass="search-field"/>

                <!-- Carte Button — blue, same position as Agenda button in culture view -->
                <Button fx:id="carteBtn" text="🗺️ Carte" onAction="#showAllParcelleCarte"
                        style="-fx-background-color: #1565C0; -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-padding: 10 18; -fx-background-radius: 12px; -fx-cursor: hand;"/>

                <Button text="➕ Ajouter Parcelle" onAction="#showAddPopup"
                        styleClass="add-button"/>
            </HBox>

            <!-- Sort Buttons — Retour also moved here to remove the extra bar -->
            <HBox alignment="CENTER" spacing="15"
                  style="-fx-background-color: #8E24AA; -fx-padding: 15;">
                <Label text="Trier par:"
                       style="-fx-text-fill: white; -fx-font-weight: bold;"/>
                <Button fx:id="statutButton" text="Statut" onAction="#sortByStatut"
                        styleClass="sort-button"/>
                <Button fx:id="surfaceButton" text="Surface" onAction="#sortBySurface"
                        styleClass="sort-button"/>
                <Button fx:id="resetButton" text="Reset" onAction="#resetSort"
                        styleClass="sort-button"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="⬅️ Retour aux Cultures" onAction="#goBackToCulture"
                        style="-fx-background-color: #2a5a3a; -fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold; -fx-padding: 8 18; -fx-background-radius: 15px; -fx-cursor: hand;"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <!-- Light Purple Gradient Background -->
        <ScrollPane fitToWidth="true" fitToHeight="true"
                    style="-fx-background: linear-gradient(to bottom, #f3e5f5 0%, #f8f4f9 100%); -fx-background-color: transparent;">
            <VBox style="-fx-background-color: transparent;">
                <padding>
                    <Insets top="20" right="20" bottom="20" left="20"/>
                </padding>
                <GridPane fx:id="parcelleGrid" hgap="20" vgap="20">
                </GridPane>
            </VBox>
        </ScrollPane>
    </center>

</BorderPane>
