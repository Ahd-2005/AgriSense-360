<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.OuvrierHome"
            style="-fx-background-color: #f5f5f5;">

    <!-- TOP BAR -->
    <top>
        <VBox style="-fx-background-color: #673AB7; -fx-padding: 20;">
            <Label fx:id="welcomeLabel"
                   style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold;" />
            <Label fx:id="roleLabel"
                   style="-fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 5 0 0 0;" />
        </VBox>
    </top>

    <!-- CENTER CONTENT -->
    <center>
        <VBox spacing="20" alignment="CENTER" style="-fx-padding: 40;">

            <Label text="Ouvrier Dashboard"
                   style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #333;" />

            <Label text="Welcome to your workspace!"
                   style="-fx-font-size: 16px; -fx-text-fill: #666;" />

            <!-- Action Buttons -->
            <VBox spacing="15" alignment="CENTER" style="-fx-max-width: 400;">

                <Button text="📋 My Tasks"
                        onAction="#handleMyTasks"
                        style="-fx-pref-width: 300; -fx-pref-height: 50; -fx-font-size: 16px;
                               -fx-background-color: #4CAF50; -fx-text-fill: white; -fx-cursor: hand;" />

                <Button text="⏰ Time Sheet"
                        onAction="#handleTimeSheet"
                        style="-fx-pref-width: 300; -fx-pref-height: 50; -fx-font-size: 16px;
                               -fx-background-color: #2196F3; -fx-text-fill: white; -fx-cursor: hand;" />

                <Button text="📁 My Projects"
                        onAction="#handleMyProjects"
                        style="-fx-pref-width: 300; -fx-pref-height: 50; -fx-font-size: 16px;
                               -fx-background-color: #FF9800; -fx-text-fill: white; -fx-cursor: hand;" />

                <Button text="👤 My Profile"
                        onAction="#handleMyProfile"
                        style="-fx-pref-width: 300; -fx-pref-height: 50; -fx-font-size: 16px;
                               -fx-background-color: #607D8B; -fx-text-fill: white; -fx-cursor: hand;" />

            </VBox>

        </VBox>
    </center>

    <!-- BOTTOM BAR -->
    <bottom>
        <HBox spacing="20" alignment="CENTER" style="-fx-padding: 20; -fx-background-color: white;">

            <Label fx:id="loginTimeLabel"
                   style="-fx-font-size: 12px; -fx-text-fill: #999;" />

            <Region HBox.hgrow="ALWAYS" />

            <Button text="🚪 Logout"
                    onAction="#handleLogout"
                    style="-fx-background-color: #f44336; -fx-text-fill: white;
                           -fx-padding: 8 20; -fx-font-size: 14px;" />
        </HBox>
    </bottom>

</BorderPane>