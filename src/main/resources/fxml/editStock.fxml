<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true" hbarPolicy="NEVER" pannable="true" stylesheets="@../css/Stockhome.css" vbarPolicy="AS_NEEDED" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.EditStockController">

    <VBox alignment="TOP_CENTER" spacing="35.0" styleClass="content">
        <padding>
            <Insets bottom="100.0" left="80.0" right="80.0" top="50.0" />
        </padding>

        <VBox alignment="CENTER" spacing="10.0">
            <Label styleClass="page-title" text="✏️ Modifier Stock" />
            <Label style="-fx-font-size: 15px; -fx-text-fill: #6b7b6e;" text="Modifiez les informations du stock sélectionné" />
        </VBox>

        <Region prefHeight="10.0" />

        <!-- Carte Informations Stock -->
        <VBox spacing="25.0" styleClass="form-card">
            <Label styleClass="card-title" text="📊 Informations Stock" />

            <VBox spacing="18.0">
                <!-- Produit ID (Affichage seulement car lecture seule) -->
                <HBox alignment="CENTER_LEFT" spacing="20.0">
                    <Label prefWidth="180" styleClass="label-bold" text="Produit *" />
                    <TextField fx:id="txtProduitId" editable="false" maxWidth="Infinity" prefWidth="550.0" styleClass="input-field-readonly" HBox.hgrow="ALWAYS" />
                </HBox>

                <!-- Quantité -->
                <HBox alignment="CENTER_LEFT" spacing="20.0">
                    <Label prefWidth="180" styleClass="label-bold" text="Quantité *" />
                    <TextField fx:id="txtQuantite" maxWidth="Infinity" prefWidth="550.0" promptText="Ex : 150.0" styleClass="input-field" HBox.hgrow="ALWAYS" />
                </HBox>

                <!-- Seuil d'alerte -->
                <HBox alignment="CENTER_LEFT" spacing="20.0">
                    <Label prefWidth="180" styleClass="label-bold" text="Seuil d'alerte" />
                    <TextField fx:id="txtSeuil" maxWidth="Infinity" prefWidth="550.0" promptText="Ex : 20.0" styleClass="input-field" HBox.hgrow="ALWAYS" />
                </HBox>

                <!-- Unité de mesure -->
                <HBox alignment="CENTER_LEFT" spacing="20.0">
                    <Label prefWidth="180" styleClass="label-bold" text="Unité de mesure *" />
                    <ComboBox fx:id="comboUnite" maxWidth="Infinity" prefWidth="550.0" promptText="Sélectionner l'unité..." styleClass="input-field" HBox.hgrow="ALWAYS" />
                </HBox>

                <!-- Date de réception -->
                <HBox alignment="CENTER_LEFT" spacing="20.0">
                    <Label prefWidth="180" styleClass="label-bold" text="Date de réception" />
                    <DatePicker fx:id="dateReception" maxWidth="Infinity" prefWidth="550.0" promptText="JJ/MM/AAAA" styleClass="input-field" HBox.hgrow="ALWAYS" />
                </HBox>

                <!-- Date d'expiration -->
                <HBox alignment="CENTER_LEFT" spacing="20.0">
                    <Label prefWidth="180" styleClass="label-bold" text="Date d'expiration" />
                    <DatePicker fx:id="dateExpiration" maxWidth="Infinity" prefWidth="550.0" promptText="JJ/MM/AAAA" styleClass="input-field" HBox.hgrow="ALWAYS" />
                </HBox>

                <!-- Emplacement -->
                <HBox alignment="CENTER_LEFT" spacing="20.0">
                    <Label prefWidth="180" styleClass="label-bold" text="Emplacement" />
                    <TextField fx:id="txtEmplacement" maxWidth="Infinity" prefWidth="550.0" promptText="Ex : Entrepôt A - Rayon 3 - Étagère 2" styleClass="input-field" HBox.hgrow="ALWAYS" />
                </HBox>
            </VBox>
        </VBox>

        <!-- Boutons d'action -->
        <VBox alignment="CENTER" spacing="20.0" styleClass="form-card">
            <HBox alignment="CENTER" spacing="20.0">
                <Button onAction="#annuler" prefHeight="45.0" prefWidth="180.0" styleClass="ghost" text="Annuler" />
                <Button fx:id="btnEnregistrer" onAction="#enregistrer" prefHeight="45.0" prefWidth="220.0" styleClass="primary" text="✓ Enregistrer Modifications" />
            </HBox>

            <Label style="-fx-font-size: 12px; -fx-text-fill: #6b7b6e; -fx-font-style: italic;" text="* Champs obligatoires" />
        </VBox>

        <Region prefHeight="50.0" />
    </VBox>
</ScrollPane>