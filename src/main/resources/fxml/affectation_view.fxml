<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.AffectationController"
            fitToWidth="true" styleClass="content">

    <VBox spacing="20" styleClass="content-inner">
        <padding><Insets top="30" right="40" bottom="40" left="40"/></padding>

        <!-- Navigation toggle -->
        <HBox spacing="0" alignment="CENTER_LEFT" style="-fx-padding: 0 0 10 0;">
            <Button text="📋 Affectations"
                    style="-fx-background-color: #5a9814; -fx-text-fill: white; -fx-font-weight: bold;
                           -fx-font-size: 13px; -fx-padding: 10 20; -fx-background-radius: 8 0 0 0;
                           -fx-cursor: hand;"
                    disable="true"/>
            <Button text="📊 Évaluations"
                    style="-fx-background-color: #e8e8e8; -fx-text-fill: #333; -fx-font-weight: bold;
                           -fx-font-size: 13px; -fx-padding: 10 20; -fx-background-radius: 0;
                           -fx-cursor: hand;"
                    onAction="#onSwitchToEvaluation"/>
            <Button text="📈 Dashboard"
                    style="-fx-background-color: #e8e8e8; -fx-text-fill: #333; -fx-font-weight: bold;
                           -fx-font-size: 13px; -fx-padding: 10 20; -fx-background-radius: 0;
                           -fx-cursor: hand;"
                    onAction="#onSwitchToDashboard"/>
            <Button text="📅 Calendrier"
                    style="-fx-background-color: #e8e8e8; -fx-text-fill: #333; -fx-font-weight: bold;
                           -fx-font-size: 13px; -fx-padding: 10 20; -fx-background-radius: 0 8 8 0;
                           -fx-cursor: hand;"
                    onAction="#onSwitchToCalendar"/>
        </HBox>

        <Label text="Gestion des Affectations de Travail" styleClass="topbar-title"/>

        <!-- Form -->
        <VBox styleClass="hero-banner" spacing="16">
            <Label text="Formulaire" styleClass="hero-kicker"/>
            <GridPane hgap="15" vgap="12">
                <Label text="Type travail:" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                <TextField fx:id="tfTypeTravail" styleClass="form-field" prefWidth="300" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                <Label text="Date début:" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                <DatePicker fx:id="dpDateDebut" prefWidth="300" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                <Label text="Date fin:" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                <DatePicker fx:id="dpDateFin" prefWidth="300" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                <Label text="Zone travail:" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                <TextField fx:id="tfZoneTravail" styleClass="form-field" prefWidth="300" GridPane.columnIndex="1" GridPane.rowIndex="3"/>

                <Label text="Statut:" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
                <ComboBox fx:id="cbStatut" prefWidth="300" GridPane.columnIndex="1" GridPane.rowIndex="4" editable="false"/>
            </GridPane>
            <HBox spacing="10">
                <Button fx:id="btnAdd" text="Ajouter" styleClass="add-button" onAction="#onAdd"/>
                <Button fx:id="btnUpdate" text="Modifier" styleClass="edit-button" onAction="#onUpdate"/>
                <Button fx:id="btnDelete" text="Supprimer" styleClass="delete-button" onAction="#onDelete"/>
                <Button fx:id="btnClear" text="Vider" styleClass="ghost" onAction="#onClear"/>
                <Separator orientation="VERTICAL" prefHeight="30"/>
                <Button fx:id="btnCheckMeteo" text="🌤️ Vérifier Météo"
                        style="-fx-background-color: #1a73e8; -fx-text-fill: white; -fx-font-weight: bold;
                               -fx-background-radius: 6; -fx-cursor: hand; -fx-padding: 7 14 7 14;"
                        onAction="#onCheckMeteo"/>
                <Button fx:id="btnAIPlan" text="🤖 Planification IA"
                        style="-fx-background-color: #7b2d8b; -fx-text-fill: white; -fx-font-weight: bold;
                               -fx-background-radius: 6; -fx-cursor: hand; -fx-padding: 7 14 7 14;"
                        onAction="#onAIPlan"/>
                <Button fx:id="btnLocaliser" text="📍 Localiser sur Carte"
                        style="-fx-background-color: #e67e22; -fx-text-fill: white; -fx-font-weight: bold;
                               -fx-background-radius: 6; -fx-cursor: hand; -fx-padding: 7 14 7 14;"
                        onAction="#onLocaliser"/>
            </HBox>
            <!-- Résultat météo -->
            <Label fx:id="lblMeteoResult"
                   wrapText="true"
                   style="-fx-font-size: 12px; -fx-padding: 6 10 6 10;
                          -fx-background-color: #f0f8ff; -fx-background-radius: 6;
                          -fx-border-color: #b0d4f1; -fx-border-radius: 6;"/>
            <!-- Résultat planification IA -->
            <Label fx:id="lblAIPlanResult"
                   wrapText="true"
                   style="-fx-font-size: 12px; -fx-padding: 6 10 6 10;
                          -fx-background-color: #f5f0ff; -fx-background-radius: 6;
                          -fx-border-color: #d1b3ff; -fx-border-radius: 6;"/>
            <!-- Résultat géocodage Google Maps -->
            <Label fx:id="lblGeoResult"
                   wrapText="true"
                   style="-fx-font-size: 12px; -fx-padding: 6 10 6 10;
                          -fx-background-color: #fff8f0; -fx-background-radius: 6;
                          -fx-border-color: #f0c878; -fx-border-radius: 6;"/>
        </VBox>

        <!-- TableView avec filtres -->
        <VBox spacing="10">
            <Label text="Liste des affectations" styleClass="section-title-main"/>

            <!-- Search and Sort Controls -->
            <HBox spacing="15" styleClass="filter-controls" style="-fx-padding: 15; -fx-background-color: #f9f9f9; -fx-border-radius: 8; -fx-border-color: #e0e0e0;">
                <Label text="🔍 Rechercher:" style="-fx-font-weight: bold;"/>
                <TextField fx:id="tfSearch" promptText="Filtrer par type de travail..." prefWidth="250" styleClass="search-field"/>

                <Separator orientation="VERTICAL" prefHeight="30"/>

                <Label text="📊 Trier par:" style="-fx-font-weight: bold;"/>
                <ComboBox fx:id="cbSort" prefWidth="200" promptText="Sélectionner ordre"/>

                <Region HBox.hgrow="ALWAYS"/>

                <Button text="🔄 Réinitialiser" styleClass="ghost" onAction="#onResetFilters" prefWidth="120"/>
            </HBox>

            <TableView fx:id="tvAffectations" prefHeight="300" styleClass="table-view" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colId" text="ID" prefWidth="60"/>
                    <TableColumn fx:id="colTypeTravail" text="Type travail" prefWidth="150"/>
                    <TableColumn fx:id="colDateDebut" text="Date début" prefWidth="100"/>
                    <TableColumn fx:id="colDateFin" text="Date fin" prefWidth="100"/>
                    <TableColumn fx:id="colZoneTravail" text="Zone travail" prefWidth="120"/>
                    <TableColumn fx:id="colStatut" text="Statut" prefWidth="100"/>
                </columns>
            </TableView>
        </VBox>
    </VBox>
</ScrollPane>