<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="controllers.AnimalController"
      spacing="20" VBox.vgrow="ALWAYS">
    <padding>
        <Insets top="0" right="0" bottom="0" left="0"/>
    </padding>

    <VBox styleClass="mgmt-form-card" spacing="0">

        <HBox styleClass="mgmt-form-card-header" alignment="CENTER_LEFT" spacing="12">
            <VBox spacing="3">
                <Label text="Add / Edit Animal" styleClass="mgmt-form-title"/>
                <Label text="Fill in the fields below, then click Add Animal or select a row to edit." styleClass="mgmt-form-subtitle"/>
            </VBox>
        </HBox>

        <VBox styleClass="mgmt-form-body" spacing="0">
            <GridPane hgap="16" vgap="11">

                <Label text="Ear Tag" styleClass="mgmt-form-label" GridPane.columnIndex="0" GridPane.rowIndex="0" GridPane.valignment="CENTER"/>
                <TextField fx:id="earTagField" promptText="Number only" styleClass="mgmt-input" GridPane.columnIndex="1" GridPane.rowIndex="0" prefWidth="140"/>

                <Label text="Type" styleClass="mgmt-form-label" GridPane.columnIndex="2" GridPane.rowIndex="0" GridPane.valignment="CENTER"/>
                <ComboBox fx:id="typeCombo" promptText="Select type" styleClass="mgmt-combo" GridPane.columnIndex="3" GridPane.rowIndex="0" prefWidth="160"/>


                <Label text="Gender" styleClass="mgmt-form-label" GridPane.columnIndex="0" GridPane.rowIndex="1" GridPane.valignment="CENTER"/>
                <ComboBox fx:id="genderCombo" promptText="Select gender" styleClass="mgmt-combo" GridPane.columnIndex="1" GridPane.rowIndex="1" prefWidth="160"/>

                <Label text="Weight (kg)" styleClass="mgmt-form-label" GridPane.columnIndex="2" GridPane.rowIndex="1" GridPane.valignment="CENTER"/>
                <TextField fx:id="weightField" promptText="e.g. 320.5" styleClass="mgmt-input" GridPane.columnIndex="3" GridPane.rowIndex="1" prefWidth="140"/>


                <Label text="Birth Date" styleClass="mgmt-form-label" GridPane.columnIndex="0" GridPane.rowIndex="2" GridPane.valignment="CENTER"/>
                <DatePicker fx:id="birthDatePicker" styleClass="mgmt-datepicker" GridPane.columnIndex="1" GridPane.rowIndex="2" prefWidth="160"/>

                <Label text="Entry Date" styleClass="mgmt-form-label" GridPane.columnIndex="2" GridPane.rowIndex="2" GridPane.valignment="CENTER"/>
                <DatePicker fx:id="entryDatePicker" styleClass="mgmt-datepicker" GridPane.columnIndex="3" GridPane.rowIndex="2" prefWidth="160"/>


                <Label text="Origin" styleClass="mgmt-form-label" GridPane.columnIndex="0" GridPane.rowIndex="3" GridPane.valignment="CENTER"/>
                <ComboBox fx:id="originCombo" promptText="Select origin" styleClass="mgmt-combo" GridPane.columnIndex="1" GridPane.rowIndex="3" prefWidth="160"/>

                <Label text="Location" styleClass="mgmt-form-label" GridPane.columnIndex="2" GridPane.rowIndex="3" GridPane.valignment="CENTER"/>
                <ComboBox fx:id="locationCombo" promptText="Select location" styleClass="mgmt-combo" GridPane.columnIndex="3" GridPane.rowIndex="3" prefWidth="160"/>


                <Label text="Vaccinated" styleClass="mgmt-form-label" GridPane.columnIndex="0" GridPane.rowIndex="4" GridPane.valignment="CENTER"/>
                <CheckBox fx:id="vaccinatedCheck" text="Yes, this animal is vaccinated" styleClass="mgmt-check"
                          GridPane.columnIndex="1" GridPane.rowIndex="4" GridPane.columnSpan="3"/>


                <HBox spacing="10" alignment="CENTER_LEFT" GridPane.columnIndex="0" GridPane.rowIndex="5" GridPane.columnSpan="4">
                    <padding><Insets top="6"/></padding>
                    <Button text="Add Animal" onAction="#onAddAnimal" styleClass="mgmt-btn-primary"/>
                    <Button text="Update" fx:id="updateAnimalBtn" onAction="#onUpdateAnimal" styleClass="mgmt-btn-ghost" disable="true"/>
                    <Button text="Delete" fx:id="deleteAnimalBtn" onAction="#onDeleteAnimal" styleClass="mgmt-btn-danger" disable="true"/>
                </HBox>
            </GridPane>
        </VBox>
    </VBox>

    <VBox styleClass="mgmt-table-card" VBox.vgrow="ALWAYS" spacing="12">
        <HBox alignment="CENTER_LEFT" spacing="12">
            <Label text="All Animals" styleClass="mgmt-table-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <ComboBox fx:id="searchFieldCombo" promptText="Search by" styleClass="mgmt-combo" prefWidth="135"/>
            <TextField fx:id="searchField" promptText="Search..." styleClass="mgmt-input" prefWidth="190"/>
            <Button text="Refresh" onAction="#onRefreshAnimals" styleClass="mgmt-btn-ghost"/>
        </HBox>
        <ScrollPane fitToWidth="true" styleClass="mgmt-scroll" VBox.vgrow="ALWAYS" minHeight="200">
            <VBox fx:id="animalTableContainer" styleClass="mgmt-table-container"/>
        </ScrollPane>
    </VBox>
</VBox>
