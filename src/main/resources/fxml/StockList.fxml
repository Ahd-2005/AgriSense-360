<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.TextField?>
<ScrollPane fitToWidth="true" pannable="true" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.StockListController" VBox.vgrow="ALWAYS" prefWidth="1530" prefHeight="800"
            stylesheets="@../css/Stockhome.css">
    <VBox alignment="TOP_CENTER" spacing="30.0">
        <padding>
            <Insets bottom="600.0" left="60.0" right="60.0" top="40.0" />
        </padding>

        <Label style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #22301b;" text="📦 Liste des Stocks" />

        <HBox alignment="CENTER_LEFT" spacing="20.0">
            <Button onAction="#goToHome" prefHeight="48.0" prefWidth="150.0" styleClass="ghost" text="🏠 Accueil" />
            <Button onAction="#goToProductList" prefHeight="48.0" prefWidth="150.0" styleClass="ghost" text="📦 Produits" />
        </HBox>
        <!-- Barre de recherche et tri -->
        <HBox alignment="CENTER_LEFT" spacing="15.0">
            <TextField fx:id="txtRecherche" promptText="🔍 Rechercher par nom de produit ou quantité..." prefHeight="44.0" prefWidth="400.0"
                       style="-fx-font-size: 14px; -fx-background-radius: 8px; -fx-border-radius: 8px; -fx-border-color: #c8d8b0; -fx-padding: 0 12px;"/>
            <ComboBox fx:id="comboTri" promptText="Trier par..." prefHeight="44.0" prefWidth="220.0"
                      style="-fx-font-size: 14px; -fx-background-radius: 8px;"/>
            <Button onAction="#reinitialiserFiltres" prefHeight="44.0" prefWidth="120.0" styleClass="ghost" text="✖ Réinitialiser" />
            <Region HBox.hgrow="ALWAYS" />
        </HBox>

        <!-- Label résultats -->
        <Label fx:id="lblResultats" style="-fx-font-size: 13px; -fx-text-fill: #6b7b6e; -fx-font-style: italic;" text="" />



        <HBox alignment="CENTER_RIGHT">
            <Button fx:id="btnAjouterStock" onAction="#ajouterStock" prefHeight="48.0" prefWidth="200.0" styleClass="primary" text="➕ Ajouter Nouveau Stock" />
        </HBox>

        <FlowPane fx:id="flowStocks" hgap="20.0" vgap="20.0" prefWrapLength="1000.0" styleClass="flow">
        </FlowPane>

        <Region prefHeight="800.0" VBox.vgrow="NEVER" />

    </VBox>
</ScrollPane>