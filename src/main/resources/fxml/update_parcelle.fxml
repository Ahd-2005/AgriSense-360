<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="15" alignment="CENTER" xmlns:fx="http://javafx.com/fxml"
      fx:controller="controllers.ParcelleController"
      style="-fx-padding: 20; -fx-background-color: #f5f5f5;">

    <Label text="✏️ Modifier une Parcelle"
           style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #9C27B0;"/>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="ID:" style="-fx-font-size: 14px; -fx-font-weight: bold;" prefWidth="100"/>
        <TextField fx:id="updateIdField" editable="false"
                   style="-fx-font-size: 14px; -fx-background-color: #e0e0e0;" prefWidth="280"/>
    </HBox>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="Nom:" style="-fx-font-size: 14px;" prefWidth="100"/>
        <TextField fx:id="updateNomField" promptText="Nom de la parcelle"
                   style="-fx-font-size: 14px;" prefWidth="280"/>
    </HBox>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="Surface (m²):" style="-fx-font-size: 14px;" prefWidth="100"/>
        <TextField fx:id="updateSurfaceField" promptText="Surface"
                   style="-fx-font-size: 14px;" prefWidth="280"/>
    </HBox>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="Localisation:" style="-fx-font-size: 14px;" prefWidth="100"/>
        <TextField fx:id="updateLocalisationField" promptText="Localisation"
                   style="-fx-font-size: 14px;" prefWidth="280"/>
    </HBox>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="Type de Sol:" style="-fx-font-size: 14px;" prefWidth="100"/>
        <TextField fx:id="updateTypeSolField" promptText="Type de sol"
                   style="-fx-font-size: 14px;" prefWidth="280"/>
    </HBox>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="Statut:" style="-fx-font-size: 14px;" prefWidth="100"/>
        <ComboBox fx:id="updateStatutComboBox" promptText="Sélectionner un statut"
                  style="-fx-font-size: 14px;" prefWidth="280"/>
    </HBox>

    <HBox spacing="10" alignment="CENTER">
        <Button text="💾 Enregistrer" onAction="#handleUpdate"
                style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 10 20;"/>

        <Button text="❌ Annuler" onAction="#goToListFromUpdate"
                style="-fx-background-color: #757575; -fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 10 20;"/>
    </HBox>

    <Label fx:id="updateMessageLabel" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>

</VBox>