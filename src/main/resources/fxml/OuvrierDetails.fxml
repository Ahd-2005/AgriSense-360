<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<ScrollPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.OuvrierDetails"
            fitToWidth="true"
            style="-fx-background-color: transparent; -fx-background: transparent;">

    <VBox spacing="25" style="-fx-padding: 40; -fx-background-color: #fbf7ef;">

        <!-- TOP HEADER -->
        <VBox spacing="8">
            <Label text="Détails de l'Ouvrier"
                   style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #22301b;" />
            <Label text="Informations complètes de l'ouvrier"
                   style="-fx-font-size: 16px; -fx-text-fill: rgba(23, 35, 24, 0.72);" />
        </VBox>

        <!-- INFO CARD -->
        <VBox spacing="20"
              style="-fx-background-color: #fff; -fx-padding: 30;
                     -fx-background-radius: 16px;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 12, 0, 0, 4);
                     -fx-border-color: rgba(43, 59, 31, 0.08); -fx-border-width: 1;
                     -fx-border-radius: 16px; -fx-max-width: 600;">

            <!-- Name and Status Header -->
            <HBox spacing="15" alignment="CENTER_LEFT">
                <Label fx:id="nameLabel" text="Nom de l'Ouvrier"
                       style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #22301b;" />
                <Region HBox.hgrow="ALWAYS" />
                <Label fx:id="statusLabel" text="ACTIVE"
                       style="-fx-padding: 8 20; -fx-background-radius: 15px;
                              -fx-font-size: 13px; -fx-font-weight: bold;" />
            </HBox>

            <Separator />

            <!-- Info Grid -->
            <GridPane hgap="25" vgap="15">
                <padding>
                    <Insets top="10" />
                </padding>

                <!-- Row 0 -->
                <Label text="🆔 ID Ouvrier:" GridPane.columnIndex="0" GridPane.rowIndex="0"
                       style="-fx-font-weight: bold; -fx-text-fill: rgba(43, 59, 31, 0.7); -fx-font-size: 14px;" />
                <Label fx:id="idLabel" GridPane.columnIndex="1" GridPane.rowIndex="0"
                       style="-fx-text-fill: #22301b; -fx-font-size: 14px;" />

                <!-- Row 1 -->
                <Label text="📧 Email:" GridPane.columnIndex="0" GridPane.rowIndex="1"
                       style="-fx-font-weight: bold; -fx-text-fill: rgba(43, 59, 31, 0.7); -fx-font-size: 14px;" />
                <Label fx:id="emailLabel" GridPane.columnIndex="1" GridPane.rowIndex="1"
                       style="-fx-text-fill: #22301b; -fx-font-size: 14px;" />

                <!-- Row 2 -->
                <Label text="📱 Téléphone:" GridPane.columnIndex="0" GridPane.rowIndex="2"
                       style="-fx-font-weight: bold; -fx-text-fill: rgba(43, 59, 31, 0.7); -fx-font-size: 14px;" />
                <Label fx:id="phoneLabel" GridPane.columnIndex="1" GridPane.rowIndex="2"
                       style="-fx-text-fill: #22301b; -fx-font-size: 14px;" />

                <!-- Row 3 -->
                <Label text="👤 Rôle:" GridPane.columnIndex="0" GridPane.rowIndex="3"
                       style="-fx-font-weight: bold; -fx-text-fill: rgba(43, 59, 31, 0.7); -fx-font-size: 14px;" />
                <Label fx:id="roleLabel" GridPane.columnIndex="1" GridPane.rowIndex="3"
                       style="-fx-text-fill: #22301b; -fx-font-size: 14px;" />

                <!-- Row 4 -->
                <Label text="📋 Tâches:" GridPane.columnIndex="0" GridPane.rowIndex="4"
                       style="-fx-font-weight: bold; -fx-text-fill: rgba(43, 59, 31, 0.7); -fx-font-size: 14px;" />
                <Label fx:id="tasksLabel" GridPane.columnIndex="1" GridPane.rowIndex="4"
                       style="-fx-text-fill: #22301b; -fx-font-size: 14px;" />
            </GridPane>

        </VBox>

        <!-- ACTION BUTTONS -->
        <VBox spacing="15">

            <!-- Primary Actions -->
            <HBox spacing="12" alignment="CENTER_LEFT">
                <Button text="✏ Modifier" onAction="#handleEdit"
                        style="-fx-background-color: #f39c12; -fx-text-fill: white;
                               -fx-padding: 12 28px; -fx-font-size: 14px; -fx-font-weight: bold;
                               -fx-background-radius: 25px; -fx-cursor: hand;
                               -fx-effect: dropshadow(gaussian, rgba(243, 156, 18, 0.3), 10, 0, 0, 4);" />

                <Button text="🗑 Supprimer" onAction="#handleDelete"
                        style="-fx-background-color: transparent; -fx-text-fill: #e74c3c;
                               -fx-border-color: #e74c3c; -fx-border-width: 2;
                               -fx-border-radius: 25px; -fx-background-radius: 25px;
                               -fx-padding: 12 28px; -fx-font-size: 14px; -fx-cursor: hand;" />

                <Region HBox.hgrow="ALWAYS" />

                <Button text="← Retour" onAction="#handleBack"
                        style="-fx-background-color: transparent; -fx-text-fill: #22301b;
                               -fx-border-color: rgba(43, 59, 31, 0.3); -fx-border-width: 2;
                               -fx-border-radius: 25px; -fx-background-radius: 25px;
                               -fx-padding: 12 28px; -fx-font-size: 14px; -fx-cursor: hand;" />
            </HBox>
        </VBox>

    </VBox>

</ScrollPane>