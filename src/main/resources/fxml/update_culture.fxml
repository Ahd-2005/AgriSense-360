<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="15" alignment="CENTER" xmlns:fx="http://javafx.com/fxml"
      fx:controller="controllers.CultureController"
      style="-fx-padding: 20; -fx-background-color: #f5f5f5;">

    <Label text="✏️ Modifier une Culture"
           style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="ID:" style="-fx-font-size: 14px; -fx-font-weight: bold;" prefWidth="80"/>
        <TextField fx:id="updateIdField" editable="false"
                   style="-fx-font-size: 14px; -fx-background-color: #e0e0e0;" prefWidth="300"/>
    </HBox>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="Type:" style="-fx-font-size: 14px;" prefWidth="80"/>
        <ComboBox fx:id="updateTypeComboBox" promptText="Sélectionner le type"
                  style="-fx-font-size: 14px;" prefWidth="300"/>
    </HBox>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="Nom:" style="-fx-font-size: 14px;" prefWidth="80"/>
        <ComboBox fx:id="updateNomComboBox" promptText="Sélectionner d'abord le type"
                  style="-fx-font-size: 14px;" prefWidth="300"/>
    </HBox>

    <VBox spacing="5">
        <Label text="Date de plantation:" style="-fx-font-size: 12px;"/>
        <DatePicker fx:id="updateDatePlantationPicker" prefWidth="380"/>
    </VBox>

    <VBox spacing="5">
        <Label text="Date de récolte:" style="-fx-font-size: 12px;"/>
        <DatePicker fx:id="updateDateRecoltePicker" prefWidth="380"/>
    </VBox>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="État:" style="-fx-font-size: 14px;" prefWidth="80"/>
        <ComboBox fx:id="updateEtatComboBox" promptText="Sélectionner un état"
                  style="-fx-font-size: 14px;" prefWidth="300"/>
    </HBox>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="Parcelle:" style="-fx-font-size: 14px;" prefWidth="80"/>
        <ComboBox fx:id="updateParcelleComboBox" promptText="Sélectionner une parcelle"
                  style="-fx-font-size: 14px;" prefWidth="300"/>
    </HBox>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="Surface (m²):" style="-fx-font-size: 14px;" prefWidth="80"/>
        <TextField fx:id="updateSurfaceField" promptText="Surface"
                   style="-fx-font-size: 14px;" prefWidth="300"/>
    </HBox>
    <HBox spacing="10" alignment="CENTER">
        <Button text="💾 Enregistrer" onAction="#handleUpdate"
                style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 10 20;"/>

        <Button text="❌ Annuler" onAction="#goToListFromUpdate"
                style="-fx-background-color: #757575; -fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 10 20;"/>
    </HBox>

    <Label fx:id="updateMessageLabel" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>

</VBox>