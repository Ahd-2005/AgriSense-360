<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.GerantProfile"
            style="-fx-background-color: #f5f7fa;">

    <center>
        <StackPane>
            <!-- VIEW MODE -->
            <VBox fx:id="viewModeContainer" spacing="30" style="-fx-padding: 40;">

                <!-- Profile Header Card -->
                <VBox style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 30;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);">
                    <HBox spacing="25" alignment="CENTER_LEFT">
                        <!-- Avatar -->
                        <Label fx:id="avatarLabel" text="👤"
                               style="-fx-font-size: 60px; -fx-background-color: #e3f2fd;
                                      -fx-background-radius: 50%; -fx-padding: 20;"/>

                        <VBox spacing="8">
                            <Label fx:id="displayNameLabel" text="Nom Utilisateur"
                                   style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                            <Label fx:id="emailDisplayLabel" text="email@example.com"
                                   style="-fx-font-size: 14px; -fx-text-fill: #7f8c8d;"/>
                            <HBox spacing="12">
                                <Label fx:id="roleLabel" text="Gérant"
                                       style="-fx-padding: 6 18; -fx-background-radius: 15px; -fx-font-size: 13px;
                                              -fx-font-weight: bold; -fx-background-color: rgba(52, 152, 219, 0.15);
                                              -fx-text-fill: #3498db;"/>
                                <Label fx:id="statusLabel" text="ACTIVE"
                                       style="-fx-padding: 6 18; -fx-background-radius: 15px; -fx-font-size: 13px;
                                              -fx-font-weight: bold; -fx-background-color: rgba(90, 152, 20, 0.15);
                                              -fx-text-fill: #5a9814;"/>
                            </HBox>
                        </VBox>

                        <Region HBox.hgrow="ALWAYS"/>

                        <Button text="✏️ Modifier" onAction="#handleEdit"
                                style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-size: 14px;
                                       -fx-font-weight: bold; -fx-padding: 12 30; -fx-background-radius: 8;
                                       -fx-cursor: hand;"/>
                    </HBox>
                </VBox>

                <!-- Profile Details Card -->
                <VBox spacing="20" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 30;
                                          -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);">
                    <Label text="📋 Informations Personnelles"
                           style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

                    <Separator/>

                    <GridPane hgap="40" vgap="20">
                        <columnConstraints>
                            <ColumnConstraints percentWidth="50"/>
                            <ColumnConstraints percentWidth="50"/>
                        </columnConstraints>

                        <!-- Left Column -->
                        <VBox spacing="6" GridPane.columnIndex="0" GridPane.rowIndex="0">
                            <Label text="ID" style="-fx-font-size: 12px; -fx-text-fill: #95a5a6; -fx-font-weight: bold;"/>
                            <Label fx:id="idLabel" text="1" style="-fx-font-size: 16px; -fx-text-fill: #34495e;"/>
                        </VBox>

                        <VBox spacing="6" GridPane.columnIndex="0" GridPane.rowIndex="1">
                            <Label text="Nom Complet" style="-fx-font-size: 12px; -fx-text-fill: #95a5a6; -fx-font-weight: bold;"/>
                            <Label fx:id="nameLabel" text="Nom" style="-fx-font-size: 16px; -fx-text-fill: #34495e;"/>
                        </VBox>

                        <VBox spacing="6" GridPane.columnIndex="0" GridPane.rowIndex="2">
                            <Label text="Email" style="-fx-font-size: 12px; -fx-text-fill: #95a5a6; -fx-font-weight: bold;"/>
                            <Label fx:id="emailLabel" text="email@example.com" style="-fx-font-size: 16px; -fx-text-fill: #34495e;"/>
                        </VBox>

                        <!-- Right Column -->
                        <VBox spacing="6" GridPane.columnIndex="1" GridPane.rowIndex="0">
                            <Label text="Téléphone" style="-fx-font-size: 12px; -fx-text-fill: #95a5a6; -fx-font-weight: bold;"/>
                            <Label fx:id="phoneLabel" text="12345678" style="-fx-font-size: 16px; -fx-text-fill: #34495e;"/>
                        </VBox>

                        <VBox spacing="6" GridPane.columnIndex="1" GridPane.rowIndex="1">
                            <Label text="Rôle" style="-fx-font-size: 12px; -fx-text-fill: #95a5a6; -fx-font-weight: bold;"/>
                            <Label fx:id="roleDetailLabel" text="Gérant" style="-fx-font-size: 16px; -fx-text-fill: #34495e;"/>
                        </VBox>
                    </GridPane>
                </VBox>
            </VBox>

            <!-- EDIT MODE -->
            <VBox fx:id="editModeContainer" spacing="25" visible="false" managed="false" style="-fx-padding: 40;">

                <VBox spacing="20" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 35;
                                          -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);">

                    <Label text="✏️ Modifier le Profil"
                           style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

                    <Separator/>

                    <GridPane hgap="25" vgap="18">
                        <columnConstraints>
                            <ColumnConstraints percentWidth="50"/>
                            <ColumnConstraints percentWidth="50"/>
                        </columnConstraints>

                        <!-- Name Field -->
                        <VBox spacing="8" GridPane.columnIndex="0" GridPane.rowIndex="0">
                            <Label text="Nom Complet *" style="-fx-font-size: 13px; -fx-text-fill: #34495e; -fx-font-weight: bold;"/>
                            <TextField fx:id="nameField" promptText="Entrez votre nom"
                                       style="-fx-pref-height: 42px; -fx-font-size: 14px; -fx-background-radius: 8;
                                              -fx-border-color: #dfe6e9; -fx-border-radius: 8;"/>
                            <Label fx:id="nameError" visible="false"
                                   style="-fx-text-fill: #e74c3c; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                        </VBox>

                        <!-- Email Field -->
                        <VBox spacing="8" GridPane.columnIndex="1" GridPane.rowIndex="0">
                            <Label text="Email *" style="-fx-font-size: 13px; -fx-text-fill: #34495e; -fx-font-weight: bold;"/>
                            <TextField fx:id="emailField" promptText="votre@email.com"
                                       style="-fx-pref-height: 42px; -fx-font-size: 14px; -fx-background-radius: 8;
                                              -fx-border-color: #dfe6e9; -fx-border-radius: 8;"/>
                            <Label fx:id="emailError" visible="false"
                                   style="-fx-text-fill: #e74c3c; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                        </VBox>

                        <!-- Phone Field -->
                        <VBox spacing="8" GridPane.columnIndex="0" GridPane.rowIndex="1">
                            <Label text="Téléphone *" style="-fx-font-size: 13px; -fx-text-fill: #34495e; -fx-font-weight: bold;"/>
                            <TextField fx:id="phoneField" promptText="12345678"
                                       style="-fx-pref-height: 42px; -fx-font-size: 14px; -fx-background-radius: 8;
                                              -fx-border-color: #dfe6e9; -fx-border-radius: 8;"/>
                            <Label fx:id="phoneError" visible="false"
                                   style="-fx-text-fill: #e74c3c; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                        </VBox>

                        <!-- Empty space for layout -->
                        <VBox GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                        <!-- Password Field -->
                        <VBox spacing="8" GridPane.columnIndex="0" GridPane.rowIndex="2">
                            <Label text="Nouveau Mot de Passe (optionnel)" style="-fx-font-size: 13px; -fx-text-fill: #34495e; -fx-font-weight: bold;"/>
                            <PasswordField fx:id="passwordField" promptText="Laisser vide pour ne pas changer"
                                           style="-fx-pref-height: 42px; -fx-font-size: 14px; -fx-background-radius: 8;
                                                  -fx-border-color: #dfe6e9; -fx-border-radius: 8;"/>
                            <Label fx:id="passwordError" visible="false"
                                   style="-fx-text-fill: #e74c3c; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                        </VBox>

                        <!-- Confirm Password Field -->
                        <VBox spacing="8" GridPane.columnIndex="1" GridPane.rowIndex="2">
                            <Label text="Confirmer le Mot de Passe" style="-fx-font-size: 13px; -fx-text-fill: #34495e; -fx-font-weight: bold;"/>
                            <PasswordField fx:id="confirmPasswordField" promptText="Confirmer le mot de passe"
                                           style="-fx-pref-height: 42px; -fx-font-size: 14px; -fx-background-radius: 8;
                                                  -fx-border-color: #dfe6e9; -fx-border-radius: 8;"/>
                            <Label fx:id="confirmPasswordError" visible="false"
                                   style="-fx-text-fill: #e74c3c; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                        </VBox>
                    </GridPane>

                    <Separator/>

                    <!-- Action Buttons -->
                    <HBox spacing="15" alignment="CENTER_RIGHT">
                        <Button text="❌ Annuler" onAction="#handleCancel"
                                style="-fx-background-color: #ecf0f1; -fx-text-fill: #34495e; -fx-font-size: 14px;
                                       -fx-font-weight: bold; -fx-padding: 12 35; -fx-background-radius: 8; -fx-cursor: hand;"/>
                        <Button text="✅ Enregistrer" onAction="#handleSave"
                                style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-size: 14px;
                                       -fx-font-weight: bold; -fx-padding: 12 35; -fx-background-radius: 8; -fx-cursor: hand;"/>
                    </HBox>
                </VBox>
            </VBox>
        </StackPane>
    </center>
</BorderPane>