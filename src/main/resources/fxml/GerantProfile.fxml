<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.shape.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.GerantProfile"
            style="-fx-background-color: #f5f7fa;">

    <center>
        <StackPane>

            <!-- ═══════════════════════════════════════════ -->
            <!-- VIEW MODE                                   -->
            <!-- ═══════════════════════════════════════════ -->
            <VBox fx:id="viewModeContainer" spacing="25" style="-fx-padding: 40;">

                <!-- Profile Header Card -->
                <VBox style="-fx-background-color: white; -fx-background-radius: 16;
                             -fx-padding: 30; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 12, 0, 0, 3);">
                    <HBox spacing="28" alignment="CENTER_LEFT">

                        <!-- ── Profile Photo (circle clip via StackPane) ── -->
                        <StackPane>
                            <!-- Circular clip background -->
                            <Circle fx:id="photoCircle" radius="65"
                                    style="-fx-fill: #e3f2fd;"/>
                            <!-- Actual image — clipped to circle shape -->
                            <ImageView fx:id="profileImageView"
                                       fitWidth="130" fitHeight="130"
                                       preserveRatio="false">
                                <clip>
                                    <Circle radius="65" centerX="65" centerY="65"/>
                                </clip>
                            </ImageView>
                        </StackPane>

                        <!-- ── User Info ── -->
                        <VBox spacing="10">
                            <Label fx:id="displayNameLabel" text="Nom Utilisateur"
                                   style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                            <Label fx:id="emailDisplayLabel" text="email@example.com"
                                   style="-fx-font-size: 14px; -fx-text-fill: #7f8c8d;"/>
                            <HBox spacing="10">
                                <Label fx:id="roleLabel" text="Gérant"
                                       style="-fx-padding: 5 16; -fx-background-radius: 20; -fx-font-size: 12px;
                                              -fx-font-weight: bold; -fx-background-color: rgba(52,152,219,0.15);
                                              -fx-text-fill: #3498db;"/>
                                <Label fx:id="statusLabel" text="ACTIVE"
                                       style="-fx-padding: 5 16; -fx-background-radius: 20; -fx-font-size: 12px;
                                              -fx-font-weight: bold; -fx-background-color: rgba(90,152,20,0.15);
                                              -fx-text-fill: #5a9814;"/>
                            </HBox>
                        </VBox>

                        <Region HBox.hgrow="ALWAYS"/>

                        <HBox spacing="12">
                            <Button text="✏️  Modifier le profil" onAction="#handleEdit"
                                    style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-size: 14px;
                                           -fx-font-weight: bold; -fx-padding: 12 28; -fx-background-radius: 10;
                                           -fx-cursor: hand;"/>
                            <Button fx:id="faceIdBtn"
                                    text="🔐  Face ID"
                                    onAction="#handleFaceVerification"
                                    style="-fx-background-color: #8e44ad; -fx-text-fill: white; -fx-font-size: 14px;
                                           -fx-font-weight: bold; -fx-padding: 12 22; -fx-background-radius: 10;
                                           -fx-cursor: hand;"/>
                        </HBox>
                    </HBox>
                </VBox>

                <!-- Profile Details Card -->
                <VBox spacing="22" style="-fx-background-color: white; -fx-background-radius: 16;
                                          -fx-padding: 30; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 12, 0, 0, 3);">

                    <Label text="📋  Informations Personnelles"
                           style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                    <Separator/>

                    <GridPane hgap="50" vgap="22">
                        <columnConstraints>
                            <ColumnConstraints percentWidth="50"/>
                            <ColumnConstraints percentWidth="50"/>
                        </columnConstraints>

                        <!-- Nom -->
                        <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="0">
                            <Label text="👤  Nom Complet" style="-fx-font-size: 11px; -fx-text-fill: #95a5a6; -fx-font-weight: bold;"/>
                            <Label fx:id="nameLabel" text="—" style="-fx-font-size: 15px; -fx-text-fill: #34495e;"/>
                        </VBox>

                        <!-- Téléphone -->
                        <VBox spacing="4" GridPane.columnIndex="1" GridPane.rowIndex="0">
                            <Label text="📞  Téléphone" style="-fx-font-size: 11px; -fx-text-fill: #95a5a6; -fx-font-weight: bold;"/>
                            <Label fx:id="phoneLabel" text="—" style="-fx-font-size: 15px; -fx-text-fill: #34495e;"/>
                        </VBox>

                        <!-- Email -->
                        <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="1">
                            <Label text="✉️  Email" style="-fx-font-size: 11px; -fx-text-fill: #95a5a6; -fx-font-weight: bold;"/>
                            <Label fx:id="emailLabel" text="—" style="-fx-font-size: 15px; -fx-text-fill: #34495e;"/>
                        </VBox>

                        <!-- Rôle -->
                        <VBox spacing="4" GridPane.columnIndex="1" GridPane.rowIndex="1">
                            <Label text="🎭  Rôle" style="-fx-font-size: 11px; -fx-text-fill: #95a5a6; -fx-font-weight: bold;"/>
                            <Label fx:id="roleDetailLabel" text="—" style="-fx-font-size: 15px; -fx-text-fill: #34495e;"/>
                        </VBox>

                    </GridPane>
                </VBox>
            </VBox>

            <!-- ═══════════════════════════════════════════ -->
            <!-- EDIT MODE                                   -->
            <!-- ═══════════════════════════════════════════ -->
            <VBox fx:id="editModeContainer" spacing="25" visible="false" managed="false" style="-fx-padding: 40;">

                <VBox spacing="22" style="-fx-background-color: white; -fx-background-radius: 16;
                                          -fx-padding: 35; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 12, 0, 0, 3);">

                    <Label text="✏️  Modifier le Profil"
                           style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                    <Separator/>

                    <!-- Photo Section in Edit Mode -->
                    <HBox spacing="25" alignment="CENTER_LEFT"
                          style="-fx-background-color: #f8f9fa; -fx-background-radius: 12; -fx-padding: 20;">

                        <StackPane>
                            <Circle radius="55" style="-fx-fill: #e3f2fd;"/>
                            <ImageView fx:id="editProfileImageView"
                                       fitWidth="110" fitHeight="110"
                                       preserveRatio="false">
                                <clip>
                                    <Circle radius="55" centerX="55" centerY="55"/>
                                </clip>
                            </ImageView>
                        </StackPane>

                        <VBox spacing="10">
                            <Label text="Photo de profil"
                                   style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                            <Label text="Choisissez une image depuis votre ordinateur"
                                   style="-fx-font-size: 12px; -fx-text-fill: #7f8c8d;"/>
                            <Button text="📂  Choisir une photo"
                                    onAction="#handleChoosePhoto"
                                    style="-fx-background-color: #3498db; -fx-text-fill: white;
                                           -fx-font-size: 13px; -fx-font-weight: bold;
                                           -fx-padding: 9 22; -fx-background-radius: 8; -fx-cursor: hand;"/>
                            <Label fx:id="editPhotoStatus" text=""
                                   style="-fx-font-size: 12px; -fx-text-fill: #388e3c;"/>
                        </VBox>
                    </HBox>

                    <Separator/>

                    <!-- Form Fields -->
                    <GridPane hgap="25" vgap="18">
                        <columnConstraints>
                            <ColumnConstraints percentWidth="50"/>
                            <ColumnConstraints percentWidth="50"/>
                        </columnConstraints>

                        <!-- Name -->
                        <VBox spacing="6" GridPane.columnIndex="0" GridPane.rowIndex="0">
                            <Label text="Nom Complet *" style="-fx-font-size: 13px; -fx-text-fill: #34495e; -fx-font-weight: bold;"/>
                            <TextField fx:id="nameField" promptText="Votre nom complet"
                                       style="-fx-pref-height: 42; -fx-font-size: 14px; -fx-background-radius: 8;
                                              -fx-border-color: #dfe6e9; -fx-border-radius: 8;"/>
                            <Label fx:id="nameError" visible="false"
                                   style="-fx-text-fill: #e74c3c; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                        </VBox>

                        <!-- Email -->
                        <VBox spacing="6" GridPane.columnIndex="1" GridPane.rowIndex="0">
                            <Label text="Email *" style="-fx-font-size: 13px; -fx-text-fill: #34495e; -fx-font-weight: bold;"/>
                            <TextField fx:id="emailField" promptText="votre@email.com"
                                       style="-fx-pref-height: 42; -fx-font-size: 14px; -fx-background-radius: 8;
                                              -fx-border-color: #dfe6e9; -fx-border-radius: 8;"/>
                            <Label fx:id="emailError" visible="false"
                                   style="-fx-text-fill: #e74c3c; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                        </VBox>

                        <!-- Phone -->
                        <VBox spacing="6" GridPane.columnIndex="0" GridPane.rowIndex="1">
                            <Label text="Téléphone *" style="-fx-font-size: 13px; -fx-text-fill: #34495e; -fx-font-weight: bold;"/>
                            <TextField fx:id="phoneField" promptText="12345678"
                                       style="-fx-pref-height: 42; -fx-font-size: 14px; -fx-background-radius: 8;
                                              -fx-border-color: #dfe6e9; -fx-border-radius: 8;"/>
                            <Label fx:id="phoneError" visible="false"
                                   style="-fx-text-fill: #e74c3c; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                        </VBox>

                        <!-- Empty -->
                        <VBox GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                        <!-- Password -->
                        <VBox spacing="6" GridPane.columnIndex="0" GridPane.rowIndex="2">
                            <Label text="Nouveau mot de passe (optionnel)"
                                   style="-fx-font-size: 13px; -fx-text-fill: #34495e; -fx-font-weight: bold;"/>
                            <PasswordField fx:id="passwordField" promptText="Laisser vide = inchangé"
                                           style="-fx-pref-height: 42; -fx-font-size: 14px; -fx-background-radius: 8;
                                                  -fx-border-color: #dfe6e9; -fx-border-radius: 8;"/>
                            <Label fx:id="passwordError" visible="false"
                                   style="-fx-text-fill: #e74c3c; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                        </VBox>

                        <!-- Confirm Password -->
                        <VBox spacing="6" GridPane.columnIndex="1" GridPane.rowIndex="2">
                            <Label text="Confirmer le mot de passe"
                                   style="-fx-font-size: 13px; -fx-text-fill: #34495e; -fx-font-weight: bold;"/>
                            <PasswordField fx:id="confirmPasswordField" promptText="Confirmer"
                                           style="-fx-pref-height: 42; -fx-font-size: 14px; -fx-background-radius: 8;
                                                  -fx-border-color: #dfe6e9; -fx-border-radius: 8;"/>
                            <Label fx:id="confirmPasswordError" visible="false"
                                   style="-fx-text-fill: #e74c3c; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                        </VBox>
                    </GridPane>

                    <Separator/>

                    <!-- Buttons -->
                    <HBox spacing="15" alignment="CENTER_RIGHT">
                        <Button text="❌  Annuler" onAction="#handleCancel"
                                style="-fx-background-color: #ecf0f1; -fx-text-fill: #34495e; -fx-font-size: 14px;
                                       -fx-font-weight: bold; -fx-padding: 12 32; -fx-background-radius: 8; -fx-cursor: hand;"/>
                        <Button text="✅  Enregistrer" onAction="#handleSave"
                                style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-size: 14px;
                                       -fx-font-weight: bold; -fx-padding: 12 32; -fx-background-radius: 8; -fx-cursor: hand;"/>
                    </HBox>
                </VBox>
            </VBox>

        </StackPane>
    </center>
</BorderPane>
