<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.GerantHome">
    <stylesheets>
        <String fx:value="@../css/user.css"/>
    </stylesheets>

    <!-- TOP BAR -->
    <top>
        <VBox styleClass="top-bar">
            <Label fx:id="welcomeLabel" styleClass="top-bar-title"/>
            <Label fx:id="roleLabel"    styleClass="top-bar-subtitle"/>
        </VBox>
    </top>

    <!-- CENTER CONTENT -->
    <center>
        <VBox spacing="20" alignment="CENTER" styleClass="page-body">
            <Label text="Tableau de Bord Gérant" styleClass="dash-heading"/>
            <Label text="Gestion de la Ferme"    styleClass="dash-sub"/>

            <!-- Action Buttons Grid -->
            <GridPane hgap="15" vgap="15" alignment="CENTER">
                <Button text="🌾 Cultures &amp; Parcelles" onAction="#handleCultures"
                        styleClass="btn-nav-tile"
                        GridPane.columnIndex="0" GridPane.rowIndex="0"
                        prefWidth="220"/>
                <Button text="📦 Stocks" onAction="#handleStocks"
                        styleClass="btn-nav-tile"
                        GridPane.columnIndex="1" GridPane.rowIndex="0"
                        prefWidth="220"/>
                <Button text="🚜 Équipements" onAction="#handleEquipements"
                        styleClass="btn-nav-tile"
                        GridPane.columnIndex="0" GridPane.rowIndex="1"
                        prefWidth="220"/>
                <Button text="🐄 Animaux" onAction="#handleAnimaux"
                        styleClass="btn-nav-tile"
                        GridPane.columnIndex="1" GridPane.rowIndex="1"
                        prefWidth="220"/>
                <Button text="👷 Gestion Ouvriers" onAction="#handleOuvriers"
                        styleClass="btn-nav-tile"
                        GridPane.columnIndex="0" GridPane.rowIndex="2"
                        GridPane.columnSpan="2"
                        prefWidth="455"/>
            </GridPane>
        </VBox>
    </center>

    <!-- BOTTOM BAR -->
    <bottom>
        <HBox spacing="20" alignment="CENTER" styleClass="bottom-bar">
            <Label fx:id="loginTimeLabel" styleClass="bottom-bar-label"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="🚪 Déconnexion" onAction="#handleLogout" styleClass="btn-logout"/>
        </HBox>
    </bottom>

</BorderPane>
