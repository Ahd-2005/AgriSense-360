<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.EvaluationController"
            fitToWidth="true" styleClass="content">

    <VBox spacing="20" styleClass="content-inner">
        <padding><Insets top="30" right="40" bottom="40" left="40"/></padding>

        <!-- Navigation toggle -->
        <HBox spacing="0" alignment="CENTER_LEFT" style="-fx-padding: 0 0 10 0;">
            <Button text="📋 Affectations"
                    style="-fx-background-color: #e8e8e8; -fx-text-fill: #333; -fx-font-weight: bold;
                           -fx-font-size: 13px; -fx-padding: 10 20; -fx-background-radius: 8 0 0 0;
                           -fx-cursor: hand;"
                    onAction="#onSwitchToAffectation"/>
            <Button text="📊 Évaluations"
                    style="-fx-background-color: #5a9814; -fx-text-fill: white; -fx-font-weight: bold;
                           -fx-font-size: 13px; -fx-padding: 10 20; -fx-background-radius: 0;
                           -fx-cursor: hand;"
                    disable="true"/>
            <Button text="📈 Dashboard"
                    style="-fx-background-color: #e8e8e8; -fx-text-fill: #333; -fx-font-weight: bold;
                           -fx-font-size: 13px; -fx-padding: 10 20; -fx-background-radius: 0;
                           -fx-cursor: hand;"
                    onAction="#onSwitchToDashboard"/>
            <Button text="📅 Calendrier"
                    style="-fx-background-color: #e8e8e8; -fx-text-fill: #333; -fx-font-weight: bold;
                           -fx-font-size: 13px; -fx-padding: 10 20; -fx-background-radius: 0 8 8 0;
                           -fx-cursor: hand;"
                    onAction="#onSwitchToCalendar"/>
        </HBox>

        <Label text="Gestion des Évaluations de Performance" styleClass="topbar-title"/>

        <!-- Form -->
        <VBox styleClass="hero-banner" spacing="16">
            <Label text="Formulaire" styleClass="hero-kicker"/>
            <GridPane hgap="15" vgap="12">
                <Label text="Affectation:" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                <ComboBox fx:id="cbAffectation" prefWidth="350" GridPane.columnIndex="1" GridPane.rowIndex="0" editable="false"/>

                <Label text="Note (1-5):" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                <TextField fx:id="tfNote" styleClass="form-field" prefWidth="80" promptText="1-5" maxWidth="80" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                <Label text="Qualité:" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                <ComboBox fx:id="cbQualite" prefWidth="200" GridPane.columnIndex="1" GridPane.rowIndex="2" editable="false"/>

                <Label text="Commentaire:" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                <TextField fx:id="tfCommentaire" styleClass="form-field" prefWidth="350" GridPane.columnIndex="1" GridPane.rowIndex="3"/>

                <Label text="Date évaluation:" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
                <DatePicker fx:id="dpDateEvaluation" prefWidth="250" GridPane.columnIndex="1" GridPane.rowIndex="4"/>
            </GridPane>
            <HBox spacing="10">
                <Button fx:id="btnAdd" text="Ajouter" styleClass="add-button" onAction="#onAdd"/>
                <Button fx:id="btnUpdate" text="Modifier" styleClass="edit-button" onAction="#onUpdate"/>
                <Button fx:id="btnDelete" text="Supprimer" styleClass="delete-button" onAction="#onDelete"/>
                <Button fx:id="btnClear" text="Vider" styleClass="ghost" onAction="#onClear"/>
                <Separator orientation="VERTICAL" prefHeight="30"/>
                <Button fx:id="btnRapportAI" text="🤖 Rapport IA"
                        style="-fx-background-color: #7b2d8b; -fx-text-fill: white; -fx-font-weight: bold;
                               -fx-background-radius: 6; -fx-cursor: hand; -fx-padding: 7 14 7 14;"
                        onAction="#onGenerateRapport"/>
            </HBox>
            <Label fx:id="lblAverageNote" style="-fx-text-fill: #5a9814; -fx-font-weight: bold;"/>
        </VBox>

        <!-- TableView avec filtres -->
        <VBox spacing="10">
            <Label text="Liste des évaluations" styleClass="section-title-main"/>
            
            <!-- Search and Sort Controls -->
            <HBox spacing="15" styleClass="filter-controls" style="-fx-padding: 15; -fx-background-color: #f9f9f9; -fx-border-radius: 8; -fx-border-color: #e0e0e0;">
                <Label text="🔍 Filtrer par qualité:" style="-fx-font-weight: bold;"/>
                <ComboBox fx:id="cbSearchQualite" prefWidth="180" promptText="Sélectionner qualité"/>
                
                <Separator orientation="VERTICAL" prefHeight="30"/>
                
                <Label text="📅 Trier par:" style="-fx-font-weight: bold;"/>
                <ComboBox fx:id="cbSortDate" prefWidth="220" promptText="Sélectionner ordre"/>
                
                <Region HBox.hgrow="ALWAYS"/>
                
                <Button text="🔄 Réinitialiser" styleClass="ghost" onAction="#onResetFilters" prefWidth="120"/>
            </HBox>
            
            <TableView fx:id="tvEvaluations" prefHeight="280" styleClass="table-view" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colIdEval" text="ID Eval" prefWidth="70"/>
                    <TableColumn fx:id="colIdAffect" text="ID Affect." prefWidth="80"/>
                    <TableColumn fx:id="colNote" text="Note" prefWidth="60"/>
                    <TableColumn fx:id="colQualite" text="Qualité" prefWidth="90"/>
                    <TableColumn fx:id="colCommentaire" text="Commentaire" prefWidth="200"/>
                    <TableColumn fx:id="colDateEval" text="Date éval." prefWidth="100"/>
                </columns>
            </TableView>
        </VBox>
    </VBox>
</ScrollPane>
