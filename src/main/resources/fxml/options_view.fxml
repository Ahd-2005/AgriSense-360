<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.OptionsController"
            fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="mgmt-scroll">

    <VBox spacing="20">
        <padding>
            <Insets top="0" right="0" bottom="24" left="0"/>
        </padding>

        <VBox spacing="2">
            <Label text="Types &amp; Emplacements" styleClass="mgmt-form-title"/>
            <Label text="Ajouter ou supprimer des types d'animaux et des emplacements" styleClass="mgmt-form-subtitle"/>
        </VBox>

        <HBox spacing="24">

            <VBox styleClass="mgmt-form-card" spacing="0" HBox.hgrow="ALWAYS" maxHeight="Infinity">
                <HBox styleClass="mgmt-form-card-header" alignment="CENTER_LEFT" spacing="0">
                    <Label text="Types d'Animaux" styleClass="mgmt-form-title"/>
                </HBox>
                <VBox styleClass="mgmt-form-body" spacing="14" VBox.vgrow="ALWAYS">
                    <ListView fx:id="typesList" styleClass="mgmt-list-view" prefHeight="180" VBox.vgrow="ALWAYS"/>
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <ComboBox fx:id="animalTypeCombo" promptText="Sélectionner ou saisir un type..."
                                  editable="true"
                                  styleClass="mgmt-combo" HBox.hgrow="ALWAYS" maxWidth="Infinity" visibleRowCount="10"/>
                        <Button text="Ajouter" onAction="#onAddType" styleClass="mgmt-btn-primary"/>
                    </HBox>
                    <Button fx:id="deleteTypeBtn" text="Supprimer le Type Sélectionné" onAction="#onDeleteType"
                            styleClass="mgmt-btn-danger" disable="true" maxWidth="Infinity"/>
                </VBox>
            </VBox>

            <VBox styleClass="mgmt-form-card" spacing="0" HBox.hgrow="ALWAYS" maxHeight="Infinity">
                <HBox styleClass="mgmt-form-card-header" alignment="CENTER_LEFT" spacing="0">
                    <Label text="Emplacements" styleClass="mgmt-form-title"/>
                </HBox>
                <VBox styleClass="mgmt-form-body" spacing="14" VBox.vgrow="ALWAYS">
                    <ListView fx:id="locationsList" styleClass="mgmt-list-view" prefHeight="180" VBox.vgrow="ALWAYS"/>
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <TextField fx:id="newLocationField" promptText="Nom du nouvel emplacement..." styleClass="mgmt-input" HBox.hgrow="ALWAYS"/>
                        <Button text="Ajouter" onAction="#onAddLocation" styleClass="mgmt-btn-primary"/>
                    </HBox>
                    <Button fx:id="deleteLocationBtn" text="Supprimer l'Emplacement Sélectionné" onAction="#onDeleteLocation"
                            styleClass="mgmt-btn-danger" disable="true" maxWidth="Infinity"/>
                </VBox>
            </VBox>

        </HBox>

        <VBox styleClass="mgmt-form-card" spacing="0">
            <HBox styleClass="mgmt-form-card-header" alignment="CENTER_LEFT" spacing="0">
                <VBox spacing="3">
                    <Label text="Rapport Email Vétérinaire" styleClass="mgmt-form-title"/>
                    <Label text="Envoyer un rapport de santé à votre vétérinaire" styleClass="mgmt-form-subtitle"/>
                </VBox>
            </HBox>
            <VBox styleClass="mgmt-form-body" spacing="14">

                <GridPane hgap="16" vgap="10">
                    <Label text="Email Vétérinaire" styleClass="mgmt-form-label"
                           GridPane.columnIndex="0" GridPane.rowIndex="0" GridPane.valignment="CENTER"/>
                    <TextField fx:id="vetEmailField" promptText=""
                               styleClass="mgmt-input" GridPane.columnIndex="1" GridPane.rowIndex="0" prefWidth="280"/>
                </GridPane>

                <Label text="Notes Supplémentaires" styleClass="mgmt-form-label"/>
                <TextArea fx:id="notesArea"
                          promptText="D'autres observations ou commentaires à ajouter ?"
                          styleClass="mgmt-input" prefHeight="100" wrapText="true"/>

                <HBox spacing="14" alignment="CENTER_LEFT">
                    <Button text="Envoyer le Rapport" onAction="#onSendVetReport" styleClass="mgmt-btn-primary"/>
                    <Label fx:id="emailStatusLabel" styleClass="mgmt-form-subtitle"/>
                </HBox>

            </VBox>
        </VBox>

        <VBox styleClass="mgmt-form-card" spacing="0">
            <HBox styleClass="mgmt-form-card-header" alignment="CENTER_LEFT" spacing="0">
                <VBox spacing="3">
                    <Label text="Entraînement du Modèle Personnalisé" styleClass="mgmt-form-title"/>
                    <Label text="Utilisez vos propres données pour de meilleures prédictions pour votre ferme" styleClass="mgmt-form-subtitle"/>
                </VBox>
            </HBox>
            <VBox styleClass="mgmt-form-body" spacing="14">

                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="Dossiers de santé en base :" styleClass="mgmt-form-label"/>
                    <Label fx:id="recordCountLabel" text="..." styleClass="ai-detail-value"/>
                </HBox>

                <Label fx:id="trainInfoLabel" text="" styleClass="mgmt-form-subtitle" wrapText="true"/>

                <HBox spacing="14" alignment="CENTER_LEFT">
                    <Button fx:id="trainModelBtn" text="Exporter &amp; Réentraîner le Modèle"
                            onAction="#onTrainModel" styleClass="mgmt-btn-primary" disable="true"/>
                    <Label fx:id="trainStatusLabel" text="" styleClass="mgmt-form-subtitle" wrapText="true"/>
                </HBox>

            </VBox>
        </VBox>

        <VBox styleClass="mgmt-form-card" spacing="0">
            <HBox styleClass="mgmt-form-card-header" alignment="CENTER_LEFT" spacing="0">
                <VBox spacing="3">
                    <Label text="Exporter un Rapport PDF" styleClass="mgmt-form-title"/>
                    <Label text="Choisissez les sections a inclure dans le rapport de la ferme" styleClass="mgmt-form-subtitle"/>
                </VBox>
            </HBox>
            <VBox styleClass="mgmt-form-body" spacing="12">
                <CheckBox fx:id="pdfSummaryCheck"
                          text="Resume de la Ferme (totaux, vaccination, animaux a risque)"
                          selected="true" styleClass="mgmt-form-label"/>
                <CheckBox fx:id="pdfAllAnimalsCheck"
                          text="Liste complete des animaux"
                          selected="true" styleClass="mgmt-form-label"/>
                <CheckBox fx:id="pdfAtRiskCheck"
                          text="Animaux a risque (malades, blesses, critiques)"
                          selected="true" styleClass="mgmt-form-label"/>
                <CheckBox fx:id="pdfRecentRecordsCheck"
                          text="Dossiers de sante recents (20 derniers)"
                          selected="false" styleClass="mgmt-form-label"/>
                <HBox spacing="14" alignment="CENTER_LEFT">
                    <Button text="Generer le Rapport PDF" onAction="#onExportPdf" styleClass="mgmt-btn-primary"/>
                    <Label fx:id="pdfStatusLabel" text="" styleClass="mgmt-form-subtitle" wrapText="true"/>
                </HBox>
            </VBox>
        </VBox>

    </VBox>
</ScrollPane>
