<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="controllers.OptionsController"
      spacing="24" VBox.vgrow="ALWAYS">
    <padding>
        <Insets top="0" right="0" bottom="0" left="0"/>
    </padding>

    <!-- Locations -->
    <VBox styleClass="mgmt-table-card" spacing="12">
        <Label text="Locations" styleClass="mgmt-table-title"/>
        <HBox spacing="12" alignment="CENTER_LEFT">
            <TextField fx:id="locationNameField" promptText="e.g. barn4, pasture1" styleClass="mgmt-input" prefWidth="180"/>
            <Button text="Add location" onAction="#onAddLocation" styleClass="mgmt-btn-primary"/>
            <Button text="Delete selected" fx:id="deleteLocationBtn" onAction="#onDeleteLocation" styleClass="mgmt-btn-danger" disable="true"/>
        </HBox>
        <TableView fx:id="locationTable" styleClass="mgmt-table" prefHeight="120">
            <columns>
                <TableColumn fx:id="colLocationId" text="ID" prefWidth="50"/>
                <TableColumn fx:id="colLocationName" text="Name" prefWidth="200"/>
            </columns>
        </TableView>
    </VBox>

    <!-- Animal types -->
    <VBox styleClass="mgmt-table-card" spacing="12">
        <Label text="Animal types" styleClass="mgmt-table-title"/>
        <HBox spacing="12" alignment="CENTER_LEFT">
            <TextField fx:id="typeNameField" promptText="e.g. horse, duck" styleClass="mgmt-input" prefWidth="180"/>
            <Button text="Add type" onAction="#onAddType" styleClass="mgmt-btn-primary"/>
            <Button text="Delete selected" fx:id="deleteTypeBtn" onAction="#onDeleteType" styleClass="mgmt-btn-danger" disable="true"/>
        </HBox>
        <TableView fx:id="typeTable" styleClass="mgmt-table" prefHeight="120">
            <columns>
                <TableColumn fx:id="colTypeId" text="ID" prefWidth="50"/>
                <TableColumn fx:id="colTypeName" text="Name" prefWidth="200"/>
            </columns>
        </TableView>
    </VBox>
</VBox>
