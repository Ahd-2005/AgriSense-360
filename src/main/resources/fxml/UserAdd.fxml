<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<ScrollPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.UserAdd"
            fitToWidth="true"
            style="-fx-background-color: transparent; -fx-background: transparent;">

    <VBox spacing="25" style="-fx-padding: 40; -fx-background-color: #fbf7ef;">

        <!-- TOP HEADER -->
        <VBox spacing="8">
            <Label text="Add New User"
                   style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #22301b;" />
            <Label text="Create a new user account with role assignment"
                   style="-fx-font-size: 16px; -fx-text-fill: rgba(23, 35, 24, 0.72);" />
        </VBox>

        <!-- FORM CARD -->
        <VBox spacing="20"
              style="-fx-background-color: #fff; -fx-padding: 35;
                     -fx-background-radius: 16px;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 12, 0, 0, 4);
                     -fx-border-color: rgba(43, 59, 31, 0.08); -fx-border-width: 1;
                     -fx-border-radius: 16px; -fx-max-width: 600;">

            <!-- Name Field -->
            <VBox spacing="5">
                <Label text="Full Name *"
                       style="-fx-font-weight: bold; -fx-text-fill: #22301b; -fx-font-size: 14px;" />
                <TextField fx:id="nameField" promptText="Enter full name"
                           style="-fx-padding: 12; -fx-background-radius: 8px;
                                 -fx-border-color: rgba(43, 59, 31, 0.2); -fx-border-radius: 8px;
                                 -fx-font-size: 14px;" />
                <Label fx:id="nameError" visible="false"
                       style="-fx-text-fill: #d32f2f; -fx-font-size: 12px; -fx-font-weight: bold;"/>
            </VBox>

            <!-- Email Field -->
            <VBox spacing="5">
                <Label text="Email Address *"
                       style="-fx-font-weight: bold; -fx-text-fill: #22301b; -fx-font-size: 14px;" />
                <TextField fx:id="emailField" promptText="user@example.com"
                           style="-fx-padding: 12; -fx-background-radius: 8px;
                                 -fx-border-color: rgba(43, 59, 31, 0.2); -fx-border-radius: 8px;
                                 -fx-font-size: 14px;" />
                <Label fx:id="emailError" visible="false"
                       style="-fx-text-fill: #d32f2f; -fx-font-size: 12px; -fx-font-weight: bold;"/>
            </VBox>

            <!-- Phone Field -->
            <VBox spacing="5">
                <Label text="Phone Number *"
                       style="-fx-font-weight: bold; -fx-text-fill: #22301b; -fx-font-size: 14px;" />
                <TextField fx:id="phoneField" promptText="+1 (555) 000-0000"
                           style="-fx-padding: 12; -fx-background-radius: 8px;
                                 -fx-border-color: rgba(43, 59, 31, 0.2); -fx-border-radius: 8px;
                                 -fx-font-size: 14px;" />
                <Label fx:id="phoneError" visible="false"
                       style="-fx-text-fill: #d32f2f; -fx-font-size: 12px; -fx-font-weight: bold;"/>
            </VBox>

            <!-- Password Field -->
            <VBox spacing="5">
                <Label text="Password *"
                       style="-fx-font-weight: bold; -fx-text-fill: #22301b; -fx-font-size: 14px;" />
                <PasswordField fx:id="passwordField" promptText="Enter secure password"
                               style="-fx-padding: 12; -fx-background-radius: 8px;
                                     -fx-border-color: rgba(43, 59, 31, 0.2); -fx-border-radius: 8px;
                                     -fx-font-size: 14px;" />
                <Label fx:id="passwordError" visible="false"
                       style="-fx-text-fill: #d32f2f; -fx-font-size: 12px; -fx-font-weight: bold;"/>
            </VBox>

            <!-- Confirm Password Field -->
            <VBox spacing="5">
                <Label text="Confirm Password *"
                       style="-fx-font-weight: bold; -fx-text-fill: #22301b; -fx-font-size: 14px;" />
                <PasswordField fx:id="confirmPasswordField" promptText="Re-enter password"
                               style="-fx-padding: 12; -fx-background-radius: 8px;
                                     -fx-border-color: rgba(43, 59, 31, 0.2); -fx-border-radius: 8px;
                                     -fx-font-size: 14px;" />
                <Label fx:id="confirmPasswordError" visible="false"
                       style="-fx-text-fill: #d32f2f; -fx-font-size: 12px; -fx-font-weight: bold;"/>
            </VBox>

            <!-- Role ComboBox -->
            <VBox spacing="5">
                <Label text="User Role *"
                       style="-fx-font-weight: bold; -fx-text-fill: #22301b; -fx-font-size: 14px;" />
                <ComboBox fx:id="roleCombo" promptText="Select user role" maxWidth="Infinity"
                          style="-fx-padding: 8; -fx-background-radius: 8px;
                                -fx-border-color: rgba(43, 59, 31, 0.2); -fx-border-radius: 8px;
                                -fx-font-size: 14px;" />
                <Label fx:id="roleError" visible="false"
                       style="-fx-text-fill: #d32f2f; -fx-font-size: 12px; -fx-font-weight: bold;"/>
            </VBox>

            <!-- Required Fields Note -->
            <Label text="* All fields are required"
                   style="-fx-text-fill: rgba(43, 59, 31, 0.6); -fx-font-size: 12px; -fx-padding: 10 0 0 0;" />

        </VBox>

        <!-- ACTION BUTTONS -->
        <HBox spacing="12" alignment="CENTER_LEFT" style="-fx-padding: 0 0 20 0;">
            <Button text="➕ Create User" onAction="#handleAddUser"
                    style="-fx-background-color: #5a9814; -fx-text-fill: white;
                           -fx-padding: 12 28px; -fx-font-size: 14px; -fx-font-weight: bold;
                           -fx-background-radius: 25px; -fx-cursor: hand;
                           -fx-effect: dropshadow(gaussian, rgba(90, 152, 20, 0.3), 10, 0, 0, 4);" />

            <Button text="Cancel" onAction="#handleCancel"
                    style="-fx-background-color: transparent; -fx-text-fill: #22301b;
                           -fx-border-color: rgba(43, 59, 31, 0.3); -fx-border-width: 2;
                           -fx-border-radius: 25px; -fx-background-radius: 25px;
                           -fx-padding: 12 28px; -fx-font-size: 14px; -fx-cursor: hand;" />
        </HBox>

    </VBox>

</ScrollPane>