<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<ScrollPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.UserDetails"
            fitToWidth="true"
            style="-fx-background-color: transparent; -fx-background: transparent;">

    <VBox spacing="25" style="-fx-padding: 40; -fx-background-color: #fbf7ef;">

        <!-- EN-TÊTE -->
        <VBox spacing="8">
            <Label text="Détails de l'utilisateur"
                   style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #22301b;" />
            <Label text="Consulter et gérer les informations de l'utilisateur"
                   style="-fx-font-size: 16px; -fx-text-fill: rgba(23, 35, 24, 0.72);" />
        </VBox>

        <!-- CARTE UTILISATEUR -->
        <VBox spacing="0"
              style="-fx-background-color: #fff; -fx-background-radius: 20px;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.10), 14, 0, 0, 5);
                     -fx-border-color: rgba(43,59,31,0.07); -fx-border-width: 1;
                     -fx-border-radius: 20px; -fx-max-width: 640;">

            <!-- Bandeau vert haut -->
            <HBox style="-fx-background-color: linear-gradient(to right, #2d7a3a, #43a047);
                         -fx-background-radius: 18 18 0 0; -fx-padding: 28 30 22 30;"
                  spacing="22" alignment="CENTER_LEFT">

                <!-- Avatar / Photo -->
                <StackPane fx:id="avatarPane" minWidth="80" minHeight="80" maxWidth="80" maxHeight="80" />

                <!-- Nom + Statut -->
                <VBox spacing="8" HBox.hgrow="ALWAYS">
                    <Label fx:id="nameLabel" text=""
                           style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: white;" />
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Label fx:id="statusLabel" text=""
                               style="-fx-padding: 5 16; -fx-background-radius: 12px;
                                      -fx-font-size: 12px; -fx-font-weight: bold;" />
                        <Label fx:id="roleBadgeLabel" text=""
                               style="-fx-padding: 5 16; -fx-background-radius: 12px;
                                      -fx-font-size: 12px; -fx-font-weight: bold;
                                      -fx-background-color: rgba(255,255,255,0.22); -fx-text-fill: white;" />
                    </HBox>
                </VBox>
            </HBox>

            <!-- Infos détaillées -->
            <VBox spacing="16" style="-fx-padding: 28 30 28 30;">

                <HBox spacing="20" alignment="CENTER_LEFT">
                    <Label text="📧 Email"
                           style="-fx-font-weight: bold; -fx-text-fill: rgba(34,48,27,0.6);
                                  -fx-font-size: 13px; -fx-min-width: 110;" />
                    <Label fx:id="emailLabel" text=""
                           style="-fx-text-fill: #22301b; -fx-font-size: 14px;" />
                </HBox>

                <Separator style="-fx-opacity: 0.3;" />

                <HBox spacing="20" alignment="CENTER_LEFT">
                    <Label text="📱 Téléphone"
                           style="-fx-font-weight: bold; -fx-text-fill: rgba(34,48,27,0.6);
                                  -fx-font-size: 13px; -fx-min-width: 110;" />
                    <Label fx:id="phoneLabel" text=""
                           style="-fx-text-fill: #22301b; -fx-font-size: 14px;" />
                </HBox>

                <Separator style="-fx-opacity: 0.3;" />

                <HBox spacing="20" alignment="CENTER_LEFT">
                    <Label text="👤 Rôle"
                           style="-fx-font-weight: bold; -fx-text-fill: rgba(34,48,27,0.6);
                                  -fx-font-size: 13px; -fx-min-width: 110;" />
                    <Label fx:id="roleLabel" text=""
                           style="-fx-text-fill: #22301b; -fx-font-size: 14px;" />
                </HBox>

            </VBox>
        </VBox>

        <!-- ACTIONS STATUT -->
        <HBox spacing="12" alignment="CENTER_LEFT"
              style="-fx-background-color: linear-gradient(from 0% 0% to 100% 100%, rgba(90,152,20,0.08), rgba(90,152,20,0.04));
                     -fx-background-radius: 14px; -fx-padding: 18 22; -fx-max-width: 640;
                     -fx-border-color: rgba(90,152,20,0.15); -fx-border-width: 1; -fx-border-radius: 14px;">
            <Label text="Actions sur le statut :"
                   style="-fx-font-weight: bold; -fx-text-fill: #22301b; -fx-font-size: 14px;" />
            <Region HBox.hgrow="ALWAYS" />
            <Button fx:id="activateBtn" text="✓ Activer" onAction="#handleActivate"
                    style="-fx-background-color: #27ae60; -fx-text-fill: white;
                           -fx-padding: 10 24; -fx-font-size: 13px; -fx-font-weight: bold;
                           -fx-background-radius: 10px; -fx-cursor: hand;" />
            <Button fx:id="blockBtn" text="🚫 Bloquer" onAction="#handleBlock"
                    style="-fx-background-color: #e74c3c; -fx-text-fill: white;
                           -fx-padding: 10 24; -fx-font-size: 13px; -fx-font-weight: bold;
                           -fx-background-radius: 10px; -fx-cursor: hand;" />
        </HBox>

        <!-- BOUTONS NAVIGATION -->
        <HBox spacing="12" alignment="CENTER_LEFT" style="-fx-padding: 0 0 20 0; -fx-max-width: 640;">
            <Button text="✏ Modifier" onAction="#handleModifier"
                    style="-fx-background-color: #f39c12; -fx-text-fill: white;
                           -fx-padding: 12 28; -fx-font-size: 14px; -fx-font-weight: bold;
                           -fx-background-radius: 25px; -fx-cursor: hand;" />
            <Button fx:id="deleteBtn" text="🗑 Supprimer" onAction="#handleDelete"
                    style="-fx-background-color: transparent; -fx-text-fill: #e74c3c;
                           -fx-border-color: #e74c3c; -fx-border-width: 2;
                           -fx-border-radius: 25px; -fx-background-radius: 25px;
                           -fx-padding: 12 28; -fx-font-size: 14px; -fx-cursor: hand;" />
            <Region HBox.hgrow="ALWAYS" />
            <Button text="← Retour" onAction="#handleBack"
                    style="-fx-background-color: transparent; -fx-text-fill: #22301b;
                           -fx-border-color: rgba(43,59,31,0.3); -fx-border-width: 2;
                           -fx-border-radius: 25px; -fx-background-radius: 25px;
                           -fx-padding: 12 28; -fx-font-size: 14px; -fx-cursor: hand;" />
        </HBox>

    </VBox>
</ScrollPane>
