<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>
<?import javafx.scene.chart.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="controllers.DashboardCultureController"
      stylesheets="@../css/dashboard.css"
      spacing="0"
      style="-fx-background-color: linear-gradient(to bottom, #e8f5e9, #f1f8f4);">

    <!-- Top Bar with Title -->
    <HBox alignment="CENTER_LEFT" spacing="20"
          style="-fx-background-color: linear-gradient(to right, #1e3c2c, #2a5a3a); -fx-padding: 30 40;">
        <Label text="🌾 Dashboard Culture - AgriSense 360"
               style="-fx-text-fill: white; -fx-font-size: 28px; -fx-font-weight: bold;"/>
    </HBox>

    <!-- Scrollable Content -->
    <ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent;">
        <VBox spacing="30" style="-fx-padding: 30 40;">

            <!-- Navigation Cards Section with FIXED Images -->
            <VBox spacing="15">
                <Label text="🚀 Gestion Rapide"
                       style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #2a5a3a;"/>

                <HBox spacing="20" alignment="CENTER">
                    <!-- Card 1: Gérer Culture with FIXED Image -->
                    <VBox fx:id="gererCultureCard" styleClass="nav-card-with-image"
                          onMouseClicked="#goToGererCulture"
                          prefWidth="400" prefHeight="220"
                          style="-fx-cursor: hand;">
                        <VBox alignment="CENTER" spacing="8" style="-fx-padding: 20;">
                            <ImageView fx:id="cultureImage" fitWidth="80" fitHeight="80" preserveRatio="true" style="-fx-background-radius: 40px;">
                                <image>
                                    <Image url="https://images.unsplash.com/photo-1574943320219-553eb213f72d?w=200&amp;h=200&amp;fit=crop" backgroundLoading="true"/>
                                </image>
                            </ImageView>
                            <Label text="Gérer les Cultures"
                                   style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2a5a3a;"/>
                            <Text text="Ajouter, modifier et suivre vos cultures"
                                  wrappingWidth="350"
                                  style="-fx-text-alignment: center; -fx-fill: #666; -fx-font-size: 13px;"/>
                        </VBox>
                    </VBox>

                    <!-- Card 2: Gérer Parcelle with FIXED Image -->
                    <VBox fx:id="gererParcelleCard" styleClass="nav-card-with-image"
                          onMouseClicked="#goToGererParcelle"
                          prefWidth="400" prefHeight="220"
                          style="-fx-cursor: hand;">
                        <VBox alignment="CENTER" spacing="8" style="-fx-padding: 20;">
                            <ImageView fx:id="parcelleImage" fitWidth="80" fitHeight="80" preserveRatio="true" style="-fx-background-radius: 40px;">
                                <image>
                                    <Image url="https://images.unsplash.com/photo-1500382017468-9049fed747ef?w=200&amp;h=200&amp;fit=crop" backgroundLoading="true"/>
                                </image>
                            </ImageView>
                            <Label text="Gérer les Parcelles"
                                   style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #7B1FA2;"/>
                            <Text text="Gérer vos terrains et leur occupation"
                                  wrappingWidth="350"
                                  style="-fx-text-alignment: center; -fx-fill: #666; -fx-font-size: 13px;"/>
                        </VBox>
                    </VBox>
                </HBox>
            </VBox>

            <!-- Charts Section with FIXED Legend Side -->
            <VBox spacing="15">
                <Label text="📊 Statistiques Visuelles"
                       style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #2a5a3a;"/>

                <HBox spacing="20" alignment="CENTER">

                    <!-- Chart 1: Surface Distribution (Pie Chart) - FIXED LEGEND SIDE -->
                    <VBox styleClass="chart-card-clickable" prefWidth="380" prefHeight="380" alignment="TOP_CENTER" spacing="10"
                          onMouseClicked="#showSurfaceChartDetails">
                        <Label text="🌍 Répartition des Surfaces"
                               style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2a5a3a; -fx-padding: 10 0 0 0;"/>
                        <PieChart fx:id="surfaceChart"
                                  legendVisible="true"
                                  legendSide="RIGHT"
                                  prefWidth="360"
                                  prefHeight="300"
                                  animated="true"
                                  startAngle="90"
                                  styleClass="surface-pie-chart"/>
                        <Label text="💡 Double-cliquez pour détails"
                               style="-fx-font-size: 11px; -fx-text-fill: #888; -fx-font-style: italic;"/>
                    </VBox>

                    <!-- Chart 2: Cultures by Type (Bar Chart) -->
                    <VBox styleClass="chart-card-clickable" prefWidth="380" prefHeight="380" alignment="TOP_CENTER" spacing="10"
                          onMouseClicked="#showCultureTypeChartDetails">
                        <Label text="🌱 Cultures par Type"
                               style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2a5a3a; -fx-padding: 10 0 0 0;"/>
                        <BarChart fx:id="cultureTypeChart"
                                  prefWidth="360"
                                  prefHeight="300"
                                  animated="true"
                                  legendVisible="false"
                                  categoryGap="20"
                                  barGap="8">
                            <xAxis>
                                <CategoryAxis side="BOTTOM" />
                            </xAxis>
                            <yAxis>
                                <NumberAxis side="LEFT" label="Nombre" />
                            </yAxis>
                        </BarChart>
                        <Label text="💡 Double-cliquez pour détails"
                               style="-fx-font-size: 11px; -fx-text-fill: #888; -fx-font-style: italic;"/>
                    </VBox>

                    <!-- Chart 3: État Distribution (Donut/Pie Chart) - FIXED LEGEND SIDE -->
                    <VBox styleClass="chart-card-clickable" prefWidth="380" prefHeight="380" alignment="TOP_CENTER" spacing="10"
                          onMouseClicked="#showEtatChartDetails">
                        <Label text="📈 Répartition par État"
                               style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2a5a3a; -fx-padding: 10 0 0 0;"/>
                        <PieChart fx:id="etatChart"
                                  legendVisible="true"
                                  legendSide="RIGHT"
                                  prefWidth="360"
                                  prefHeight="300"
                                  animated="true"
                                  startAngle="90"
                                  styleClass="etat-pie-chart"/>
                        <Label text="💡 Double-cliquez pour détails"
                               style="-fx-font-size: 11px; -fx-text-fill: #888; -fx-font-style: italic;"/>
                    </VBox>

                </HBox>
            </VBox>

            <!-- Summary Stats Cards -->
            <VBox spacing="15">
                <Label text="📊 Résumé Rapide"
                       style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #2a5a3a;"/>

                <HBox spacing="20" alignment="CENTER">
                    <!-- Total Cultures -->
                    <VBox styleClass="stat-card-mini" prefWidth="180" prefHeight="100" alignment="CENTER" spacing="5">
                        <Label text="🌱" style="-fx-font-size: 30px;"/>
                        <Label fx:id="totalCulturesLabel" text="0"
                               style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #4CAF50;"/>
                        <Label text="Cultures" style="-fx-font-size: 12px; -fx-text-fill: #666;"/>
                    </VBox>

                    <!-- Total Parcelles -->
                    <VBox styleClass="stat-card-mini" prefWidth="180" prefHeight="100" alignment="CENTER" spacing="5">
                        <Label text="🌍" style="-fx-font-size: 30px;"/>
                        <Label fx:id="totalParcellesLabel" text="0"
                               style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #9C27B0;"/>
                        <Label text="Parcelles" style="-fx-font-size: 12px; -fx-text-fill: #666;"/>
                    </VBox>

                    <!-- Surface Totale -->
                    <VBox styleClass="stat-card-mini" prefWidth="180" prefHeight="100" alignment="CENTER" spacing="5">
                        <Label text="📏" style="-fx-font-size: 30px;"/>
                        <Label fx:id="surfaceTotaleLabel" text="0 m²"
                               style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #2196F3;"/>
                        <Label text="Surface Totale" style="-fx-font-size: 12px; -fx-text-fill: #666;"/>
                    </VBox>

                    <!-- Taux d'Occupation -->
                    <VBox styleClass="stat-card-mini" prefWidth="180" prefHeight="100" alignment="CENTER" spacing="5">
                        <Label text="📊" style="-fx-font-size: 30px;"/>
                        <Label fx:id="tauxOccupationLabel" text="0%"
                               style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #FF9800;"/>
                        <Label text="Taux d'Occupation" style="-fx-font-size: 12px; -fx-text-fill: #666;"/>
                    </VBox>

                    <!-- Cultures Prêtes -->
                    <VBox styleClass="stat-card-mini" prefWidth="180" prefHeight="100" alignment="CENTER" spacing="5">
                        <Label text="🌾" style="-fx-font-size: 30px;"/>
                        <Label fx:id="culturesRetesLabel" text="0"
                               style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #4CAF50;"/>
                        <Label text="Prêtes à Récolter" style="-fx-font-size: 12px; -fx-text-fill: #666;"/>
                    </VBox>

                    <!-- En Retard -->
                    <VBox styleClass="stat-card-mini" prefWidth="180" prefHeight="100" alignment="CENTER" spacing="5">
                        <Label text="⚠️" style="-fx-font-size: 30px;"/>
                        <Label fx:id="culturesRetardLabel" text="0"
                               style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #f44336;"/>
                        <Label text="En Retard" style="-fx-font-size: 12px; -fx-text-fill: #666;"/>
                    </VBox>
                </HBox>
            </VBox>

            <!-- Top 3 Parcelles - ENHANCED WITH CULTURE COUNT -->
            <VBox spacing="15">
                <Label text="🏆 Top 3 Parcelles les Plus Occupées"
                       style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #2a5a3a;"/>
                <VBox fx:id="topParcellesBox" spacing="10" style="-fx-padding: 10;"/>
            </VBox>

            <!-- Cultures à Récolter Bientôt -->
            <VBox spacing="15">
                <HBox alignment="CENTER_LEFT" spacing="15">
                    <Label text="⏰ Récolte Prévue (7 jours)"
                           style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #FF9800;"/>
                    <Label fx:id="recoltePrevueCountBadge" text="0"
                           style="-fx-background-color: #FF9800; -fx-text-fill: white; -fx-padding: 5 15; -fx-background-radius: 15px; -fx-font-weight: bold;"/>
                </HBox>
                <ScrollPane fitToHeight="true" style="-fx-background: transparent; -fx-background-color: transparent;">
                    <HBox fx:id="recoltePrevueBox" spacing="15" style="-fx-padding: 10;"/>
                </ScrollPane>
            </VBox>

            <!-- Cultures en Retard -->
            <VBox spacing="15">
                <HBox alignment="CENTER_LEFT" spacing="15">
                    <Label text="⚠️ Récolte en Retard"
                           style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #f44336;"/>
                    <Label fx:id="recolteRetardCountBadge" text="0"
                           style="-fx-background-color: #f44336; -fx-text-fill: white; -fx-padding: 5 15; -fx-background-radius: 15px; -fx-font-weight: bold;"/>
                </HBox>
                <ScrollPane fitToHeight="true" style="-fx-background: transparent; -fx-background-color: transparent;">
                    <HBox fx:id="recolteRetardBox" spacing="15" style="-fx-padding: 10;"/>
                </ScrollPane>
            </VBox>

        </VBox>
    </ScrollPane>

</VBox>
