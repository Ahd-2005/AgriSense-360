<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="controllers.EnumManagementController"
      spacing="24" VBox.vgrow="ALWAYS">
    <padding>
        <Insets top="0" right="0" bottom="0" left="0"/>
    </padding>

    <Label text="Manage animal types and locations (ENUM values in DB). Changes apply to the Animal table only." styleClass="mgmt-form-title" wrapText="true"/>

    <HBox spacing="32" HBox.hgrow="ALWAYS">

        <VBox styleClass="mgmt-form-card" spacing="12" HBox.hgrow="ALWAYS" maxWidth="400">
            <Label text="Animal types" styleClass="mgmt-form-title"/>
            <ListView fx:id="typesList" styleClass="mgmt-table" prefHeight="180" VBox.vgrow="NEVER"/>
            <HBox spacing="8" alignment="CENTER_LEFT">
                <TextField fx:id="newTypeField" promptText="New type (e.g. duck)" styleClass="mgmt-input" prefWidth="160"/>
                <Button text="Add type" onAction="#onAddType" styleClass="mgmt-btn-primary"/>
            </HBox>
            <Button text="Delete selected type" onAction="#onDeleteType" styleClass="mgmt-btn-ghost" fx:id="deleteTypeBtn" disable="true"/>
        </VBox>


        <VBox styleClass="mgmt-form-card" spacing="12" HBox.hgrow="ALWAYS" maxWidth="400">
            <Label text="Locations" styleClass="mgmt-form-title"/>
            <ListView fx:id="locationsList" styleClass="mgmt-table" prefHeight="180" VBox.vgrow="NEVER"/>
            <HBox spacing="8" alignment="CENTER_LEFT">
                <TextField fx:id="newLocationField" promptText="New location (e.g. barn4)" styleClass="mgmt-input" prefWidth="160"/>
                <Button text="Add location" onAction="#onAddLocation" styleClass="mgmt-btn-primary"/>
            </HBox>
            <Button text="Delete selected location" onAction="#onDeleteLocation" styleClass="mgmt-btn-ghost" fx:id="deleteLocationBtn" disable="true"/>
        </VBox>
    </HBox>
</VBox>
