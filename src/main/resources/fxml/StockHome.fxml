<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<?import javafx.scene.layout.Region?>
<BorderPane prefHeight="800.0" prefWidth="1400.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.FrontHomeController" stylesheets="@../css/Stockhome.css">

    <center>
        <VBox alignment="TOP_CENTER" spacing="40.0" styleClass="content">
            <padding>
                <Insets bottom="40.0" left="60.0" right="60.0" top="60.0"/>
            </padding>

            <!-- Titre principal -->
            <Label style="-fx-font-size: 38px; -fx-font-weight: bold; -fx-text-fill: #22301b;" text="🏠 Gestion Produits et Stocks"/>

            <Label style="-fx-font-size: 18px; -fx-text-fill: #6b7b5a; -fx-alignment: center;" text="Gérez vos produits, stocks et alertes en toute simplicité."/>

            <!-- Statistiques en cartes -->
            <HBox alignment="CENTER" spacing="30.0">
                <VBox spacing="12.0" styleClass="stat-card">
                    <Label style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #22301b;" fx:id="statProduits" text="0"/>
                    <Label style="-fx-font-size: 14px; -fx-text-fill: #6b7b5a;" text="Produits enregistrés"/>
                </VBox>

                <VBox spacing="12.0" styleClass="stat-card">
                    <Label style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #22301b;" fx:id="statStocks" text="0"/>
                    <Label style="-fx-font-size: 14px; -fx-text-fill: #6b7b5a;" text="Stocks suivis"/>
                </VBox>

                <VBox spacing="12.0" styleClass="stat-card" fx:id="statAlertesCard">
                    <Label style="-fx-font-size: 28px; -fx-font-weight: bold;" fx:id="statAlertes" text="0"/>
                    <Label style="-fx-font-size: 14px; -fx-text-fill: #6b7b5a;" text="Alertes actives"/>
                </VBox>
            </HBox>

            <!-- Boutons d'action rapides -->
            <HBox alignment="CENTER" spacing="30.0" style="-fx-padding: 20;">
                <Button onAction="#goToProductList" prefHeight="70.0" prefWidth="280.0" styleClass="primary" text="📦 Produits"/>
                <Button onAction="#goToStockList" prefHeight="70.0" prefWidth="280.0" styleClass="primary" text="📊 Stocks"/>
                <Button onAction="#goToCommodityPrice" prefHeight="70.0" prefWidth="280.0" styleClass="primary" text="💹 Prix Marché"/>
            </HBox>

            <VBox spacing="16.0"
                  style="-fx-background-color: #fff8e1; -fx-background-radius: 14px;
                         -fx-padding: 22px 24px; -fx-border-color: #ffca28; -fx-border-radius: 14px;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 8, 0, 0, 3);">

                <HBox alignment="CENTER_LEFT" spacing="14">
                    <Label text="&#x1F6A8;  Alertes Stock Actives"
                           style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #ef6c00;"/>
                    <Label text="Stocks en dessous du seuil d'alerte"
                           style="-fx-font-size: 13px; -fx-text-fill: #888; -fx-font-style: italic;"/>
                </HBox>

                <ScrollPane fitToWidth="true" prefHeight="250.0"
                            style="-fx-background-color: transparent; -fx-border-color: transparent;">
                    <VBox fx:id="alertesContainer" spacing="10.0" alignment="TOP_LEFT">
                        <padding><Insets right="8"/></padding>
                    </VBox>
                </ScrollPane>

            </VBox>

            <Region VBox.vgrow="ALWAYS"/>
        </VBox>
    </center>
</BorderPane>