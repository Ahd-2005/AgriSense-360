<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="15" alignment="CENTER" xmlns:fx="http://javafx.com/fxml"
      fx:controller="controllers.ParcelleController"
      style="-fx-padding: 20; -fx-background-color: #f5f5f5;">

    <Label text="➕ Ajouter une Parcelle"
           style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #9C27B0;"/>

    <TextField fx:id="nomField" promptText="Nom de la parcelle (min 3 caractères)"
               style="-fx-font-size: 14px;" prefWidth="300"/>

    <TextField fx:id="surfaceField" promptText="Surface en m² (nombre positif)"
               style="-fx-font-size: 14px;" prefWidth="300"/>

    <TextField fx:id="localisationField" promptText="Localisation (min 3 caractères)"
               style="-fx-font-size: 14px;" prefWidth="300"/>

    <TextField fx:id="typeSolField" promptText="Type de sol (min 3 lettres)"
               style="-fx-font-size: 14px;" prefWidth="300"/>

    <ComboBox fx:id="statutComboBox" promptText="Sélectionner un statut"
              style="-fx-font-size: 14px;" prefWidth="300"/>

    <HBox spacing="10" alignment="CENTER">
        <Button text="✅ Ajouter" onAction="#handleAddParcelle"
                style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 10 20;"/>

        <Button text="📋 Afficher Parcelles" onAction="#goToList"
                style="-fx-background-color: #9C27B0; -fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 10 20;"/>
    </HBox>

    <Label fx:id="messageLabel" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>

</VBox>