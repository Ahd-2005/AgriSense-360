<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="controllers.MesTachesController"
      spacing="20"
      style="-fx-padding: 40; -fx-background-color: #f5f5f5;">

    <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-padding: 0 0 20 0;">
        <VBox spacing="5" HBox.hgrow="ALWAYS">
            <Label text="📋 Mes Tâches"
                   style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #2e7d32;" />
            <Label fx:id="welcomeLabel" text="Bienvenue"
                   style="-fx-text-fill: #546e7a; -fx-font-size: 16px;" />
        </VBox>
    </HBox>

    <VBox spacing="15" style="-fx-background-color: white; -fx-background-radius: 16px;
                           -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 12, 0, 0, 4);
                           -fx-padding: 30;">

        <Label text="Aucune tâche pour le moment"
               style="-fx-font-size: 18px; -fx-text-fill: #546e7a; -fx-padding: 50;" />

        <!-- You can add a TableView here for actual tasks -->
    </VBox>

</VBox>