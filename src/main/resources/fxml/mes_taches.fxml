<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<ScrollPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.MesTaches"
            fitToWidth="true"
            style="-fx-background-color: transparent; -fx-background: transparent;">

    <fx:define>
        <ToggleGroup fx:id="filterGroup" />
    </fx:define>

    <VBox spacing="25" style="-fx-padding: 40; -fx-background-color: #fbf7ef;">

        <VBox spacing="8">
            <HBox spacing="14" alignment="CENTER_LEFT">
                <Label text="📋" style="-fx-font-size: 30px;" />
                <VBox spacing="3">
                    <Label text="Mes Tâches"
                           style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #22301b;" />
                    <Label fx:id="welcomeLabel" text=""
                           style="-fx-font-size: 15px; -fx-text-fill: rgba(23,35,24,0.65);" />
                </VBox>
            </HBox>
        </VBox>

        <HBox fx:id="statsBar" spacing="16" />

        <HBox spacing="12" alignment="CENTER_LEFT"
              style="-fx-background-color: white; -fx-background-radius: 12px;
                     -fx-padding: 14 18; -fx-border-color: rgba(43,59,31,0.08);
                     -fx-border-width: 1; -fx-border-radius: 12px;">
            <Label text="Afficher :"
                   style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #555;" />
            <ToggleButton fx:id="btnTous" text="Toutes"
                          toggleGroup="$filterGroup" onAction="#handleFilter"
                          style="-fx-background-radius:20px;-fx-cursor:hand;-fx-font-size:12px;-fx-padding:7 16;" />
            <ToggleButton fx:id="btnEnAttente" text="En attente"
                          toggleGroup="$filterGroup" onAction="#handleFilter"
                          style="-fx-background-radius:20px;-fx-cursor:hand;-fx-font-size:12px;-fx-padding:7 16;" />
            <ToggleButton fx:id="btnEnCours" text="En cours"
                          toggleGroup="$filterGroup" onAction="#handleFilter"
                          style="-fx-background-radius:20px;-fx-cursor:hand;-fx-font-size:12px;-fx-padding:7 16;" />
            <ToggleButton fx:id="btnTerminees" text="Terminees"
                          toggleGroup="$filterGroup" onAction="#handleFilter"
                          style="-fx-background-radius:20px;-fx-cursor:hand;-fx-font-size:12px;-fx-padding:7 16;" />
        </HBox>

        <VBox fx:id="tachesContainer" spacing="12" />

    </VBox>
</ScrollPane>