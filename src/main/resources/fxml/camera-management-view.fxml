<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.control.cell.PropertyValueFactory?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.agrisense360.controllers.CameraManagementController"
            style="-fx-font-family: 'Segoe UI'; -fx-font-size: 12;">

    <top>
        <VBox style="-fx-background-color: #f5f5f5; -fx-padding: 15;" spacing="10">
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Camera Management" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="+ Add Camera" onAction="#handleAddCamera" 
                        style="-fx-padding: 10 20; -fx-font-size: 12; -fx-background-color: #27ae60; -fx-text-fill: white; -fx-border-radius: 5; -fx-background-radius: 5; -fx-cursor: hand;"/>
                <Button text="Export Report" onAction="#handleExportReport"
                        style="-fx-padding: 10 20; -fx-font-size: 12; -fx-background-color: #2980b9; -fx-text-fill: white; -fx-border-radius: 5; -fx-background-radius: 5; -fx-cursor: hand;"/>
            </HBox>
            <HBox spacing="10">
                <TextField fx:id="searchField" promptText="Search cameras..." style="-fx-padding: 8;" HBox.hgrow="ALWAYS"/>
                <ComboBox fx:id="sensitivityFilterCombo" promptText="Filter by Sensitivity" style="-fx-padding: 8;"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <TableView fx:id="cameraTable" style="-fx-font-size: 11;">
            <columns>
                <TableColumn text="Camera Name" prefWidth="150" sortable="true">
                    <cellValueFactory>
                        <PropertyValueFactory property="cameraName"/>
                    </cellValueFactory>
                </TableColumn>
                <TableColumn text="Location" prefWidth="120" sortable="true">
                    <cellValueFactory>
                        <PropertyValueFactory property="location"/>
                    </cellValueFactory>
                </TableColumn>
                <TableColumn text="Sensitivity" prefWidth="100" sortable="true">
                    <cellValueFactory>
                        <PropertyValueFactory property="sensitivityLevel"/>
                    </cellValueFactory>
                </TableColumn>
                <TableColumn text="Alerts Enabled" prefWidth="100" sortable="true">
                    <cellValueFactory>
                        <PropertyValueFactory property="alertsEnabled"/>
                    </cellValueFactory>
                </TableColumn>
                <TableColumn text="Status" prefWidth="80" sortable="true">
                    <cellValueFactory>
                        <PropertyValueFactory property="active"/>
                    </cellValueFactory>
                </TableColumn>
            </columns>
            <contextMenu>
                <ContextMenu>
                    <items>
                        <MenuItem text="📹 Monitor" onAction="#handleMonitorCamera"/>
                        <MenuItem text="✏️ Edit" onAction="#handleEditCamera"/>
                        <MenuItem text="🗑️ Delete" onAction="#handleDeleteCamera"/>
                    </items>
                </ContextMenu>
            </contextMenu>
        </TableView>
    </center>

    <bottom>
        <HBox style="-fx-background-color: #ecf0f1; -fx-padding: 10;" alignment="CENTER_RIGHT">
            <Label fx:id="statusLabel" text="Ready" style="-fx-text-fill: #7f8c8d;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="cameraCountLabel" style="-fx-text-fill: #7f8c8d;"/>
        </HBox>
    </bottom>

</BorderPane>
