<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.shape.Circle?>

<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.agrisense360.controllers.CameraMonitoringController"
            style="-fx-font-family: 'Segoe UI'; -fx-font-size: 12;">

    <top>
        <VBox style="-fx-background-color: #2c3e50; -fx-padding: 15;">
            <HBox spacing="15" alignment="CENTER_LEFT">
                <Label fx:id="cameraNameLabel" text="Camera Feed" style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: white;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="← Back" onAction="#handleBackToList"
                       style="-fx-padding: 8 15; -fx-font-size: 11; -fx-background-color: #34495e; -fx-text-fill: white; -fx-border-radius: 3; -fx-background-radius: 3; -fx-cursor: hand;"/>
            </HBox>
            <HBox spacing="10" style="-fx-padding: 10 0 0 0;">
                <Label text="Stream URL:" style="-fx-text-fill: #ecf0f1; -fx-font-size: 10;"/>
                <Label fx:id="streamUrlLabel" style="-fx-text-fill: #bdc3c7; -fx-font-size: 10; -fx-font-family: monospace;"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <HBox spacing="15" style="-fx-padding: 15;">
            <!-- Live Stream Panel -->
            <VBox spacing="10" HBox.hgrow="ALWAYS">
                <HBox style="-fx-border-color: #bdc3c7; -fx-border-width: 1; -fx-background-color: #1c1c1c;" alignment="CENTER" prefHeight="400">
                    <ImageView fx:id="streamImageView" preserveRatio="true" fitHeight="400" fitWidth="700" style="-fx-background-color: black;"/>
                </HBox>
                <HBox spacing="10">
                    <Button text="Start Monitoring" onAction="#handleStartMonitoring" fx:id="startButton"
                           style="-fx-padding: 10 20; -fx-font-size: 12; -fx-background-color: #27ae60; -fx-text-fill: white; -fx-border-radius: 5; -fx-background-radius: 5; -fx-cursor: hand;"/>
                    <Button text="Stop Monitoring" onAction="#handleStopMonitoring" fx:id="stopButton" disable="true"
                           style="-fx-padding: 10 20; -fx-font-size: 12; -fx-background-color: #e74c3c; -fx-text-fill: white; -fx-border-radius: 5; -fx-background-radius: 5; -fx-cursor: hand;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="fpsLabel" text="FPS: 0" style="-fx-text-fill: #7f8c8d;"/>
                </HBox>
            </VBox>

            <!-- Motion Detection Panel -->
            <VBox spacing="10" style="-fx-border-color: #bdc3c7; -fx-border-width: 1; -fx-padding: 15; -fx-background-color: #f9f9f9;" prefWidth="280">
                <Label text="📊 Motion Detection Status" style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                <Separator/>

                <!-- Sensitivity Info -->
                <VBox spacing="5">
                    <Label text="Sensitivity Mode:" style="-fx-font-weight: bold; -fx-text-fill: #34495e;"/>
                    <Label fx:id="sensitivityLabel" text="Day Mode" style="-fx-font-size: 13; -fx-text-fill: #2980b9;"/>
                </VBox>

                <Separator/>

                <!-- Motion Indicator -->
                <VBox spacing="8" style="-fx-border-color: #ecf0f1; -fx-border-width: 1; -fx-padding: 10; -fx-background-color: white;">
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Circle fx:id="motionIndicatorCircle" radius="12" style="-fx-fill: #95a5a6;"/>
                        <Label text="Motion Status:" style="-fx-font-weight: bold;"/>
                    </HBox>
                    <Label fx:id="motionStatusLabel" text="No Motion Detected" style="-fx-font-size: 12; -fx-text-fill: #27ae60; -fx-padding: 5;"/>
                </VBox>

                <Separator/>

                <!-- Real-time Stats -->
                <VBox spacing="8" style="-fx-padding: 10; -fx-background-color: #ecf0f1;">
                    <HBox spacing="10">
                        <Label text="Frames Processed:" style="-fx-font-weight: bold; -fx-text-fill: #34495e;"/>
                        <Label fx:id="frameCountLabel" text="0" style="-fx-text-fill: #2980b9; -fx-font-size: 12;"/>
                    </HBox>
                    <HBox spacing="10">
                        <Label text="Motion Countdown:" style="-fx-font-weight: bold; -fx-text-fill: #34495e;"/>
                        <Label fx:id="motionCountdownLabel" text="0" style="-fx-text-fill: #e74c3c; -fx-font-size: 12;"/>
                    </HBox>
                    <HBox spacing="10">
                        <Label text="Current Severity:" style="-fx-font-weight: bold; -fx-text-fill: #34495e;"/>
                        <Label fx:id="severityLabel" text="--" style="-fx-text-fill: #f39c12; -fx-font-size: 12;"/>
                    </HBox>
                </VBox>

                <Separator/>

                <!-- Recent Events -->
                <Label text="🔔 Recent Motion Events" style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                <ListView fx:id="motionEventsList" prefHeight="150" style="-fx-font-size: 10;"/>

                <Button text="Export Events" onAction="#handleExportEvents"
                       style="-fx-padding: 8 15; -fx-font-size: 11; -fx-background-color: #3498db; -fx-text-fill: white; -fx-border-radius: 3; -fx-background-radius: 3; -fx-cursor: hand;"/>
            </VBox>
        </HBox>
    </center>

    <bottom>
        <HBox style="-fx-background-color: #ecf0f1; -fx-padding: 10;" alignment="CENTER_LEFT" spacing="10">
            <Label fx:id="statusLabel" text="Ready" style="-fx-text-fill: #7f8c8d;"/>
            <Separator orientation="VERTICAL"/>
            <Label text="⚠️" style="-fx-text-fill: #f39c12;"/>
            <Label fx:id="alertLabel" text="Monitoring not started" style="-fx-text-fill: #e74c3c;"/>
        </HBox>
    </bottom>

</BorderPane>
