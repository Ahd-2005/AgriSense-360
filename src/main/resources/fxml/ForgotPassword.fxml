<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.ForgotPasswordController"
            style="-fx-background-color: #e8f5e9;">
    <center>
        <VBox alignment="CENTER" spacing="20" style="-fx-padding: 50; -fx-max-width: 420;">

            <Label text="🌱 AgriSense 360"
                   style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: #2e7d32;" />

            <Label text="Mot de passe oublié"
                   style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #333;" />

            <Label text="Entrez votre email pour recevoir un code de réinitialisation"
                   style="-fx-font-size: 14px; -fx-text-fill: #546e7a; -fx-wrap-text: true;"
                   wrapText="true" maxWidth="380" />

            <!-- Step 1: Email -->
            <VBox fx:id="step1Box" spacing="15" maxWidth="380">

                <VBox spacing="5">
                    <TextField fx:id="emailField" promptText="Votre email"
                               style="-fx-pref-height: 45; -fx-font-size: 15px;
                                      -fx-background-radius: 10; -fx-border-radius: 10;" />
                    <Label fx:id="emailError" visible="false"
                           style="-fx-text-fill: #d32f2f; -fx-font-size: 12px; -fx-font-weight: bold;" />
                </VBox>

                <Button text="Envoyer le code"
                        onAction="#handleSendCode"
                        style="-fx-background-color: #4CAF50; -fx-text-fill: white;
                               -fx-pref-height: 45; -fx-font-size: 15px; -fx-font-weight: bold;
                               -fx-background-radius: 10; -fx-cursor: hand;"
                        maxWidth="Infinity" />

                <Label fx:id="sendingLabel" text="⏳ Envoi en cours..." visible="false"
                       style="-fx-text-fill: #2e7d32; -fx-font-size: 13px;" />
            </VBox>

            <!-- Step 2: Code + New Password -->
            <VBox fx:id="step2Box" spacing="15" maxWidth="380" visible="false" managed="false">

                <Label text="✅ Code envoyé ! Vérifiez votre email."
                       style="-fx-text-fill: #2e7d32; -fx-font-size: 13px; -fx-font-weight: bold;" />

                <VBox spacing="5">
                    <TextField fx:id="codeField" promptText="Code à 6 chiffres"
                               style="-fx-pref-height: 45; -fx-font-size: 20px; -fx-font-weight: bold;
                                      -fx-background-radius: 10; -fx-border-radius: 10;
                                      -fx-alignment: center;" />
                    <Label fx:id="codeError" visible="false"
                           style="-fx-text-fill: #d32f2f; -fx-font-size: 12px; -fx-font-weight: bold;" />
                </VBox>

                <VBox spacing="5">
                    <PasswordField fx:id="newPasswordField" promptText="Nouveau mot de passe"
                                   style="-fx-pref-height: 45; -fx-font-size: 15px;
                                          -fx-background-radius: 10; -fx-border-radius: 10;" />
                    <Label fx:id="passwordError" visible="false"
                           style="-fx-text-fill: #d32f2f; -fx-font-size: 12px; -fx-font-weight: bold;" />
                </VBox>

                <VBox spacing="5">
                    <PasswordField fx:id="confirmPasswordField" promptText="Confirmer le mot de passe"
                                   style="-fx-pref-height: 45; -fx-font-size: 15px;
                                          -fx-background-radius: 10; -fx-border-radius: 10;" />
                    <Label fx:id="confirmError" visible="false"
                           style="-fx-text-fill: #d32f2f; -fx-font-size: 12px; -fx-font-weight: bold;" />
                </VBox>

                <Button text="Réinitialiser le mot de passe"
                        onAction="#handleResetPassword"
                        style="-fx-background-color: #4CAF50; -fx-text-fill: white;
                               -fx-pref-height: 45; -fx-font-size: 15px; -fx-font-weight: bold;
                               -fx-background-radius: 10; -fx-cursor: hand;"
                        maxWidth="Infinity" />

                <Label fx:id="successLabel" visible="false"
                       style="-fx-text-fill: #2e7d32; -fx-font-size: 13px; -fx-font-weight: bold;" />
            </VBox>

            <!-- Back to login -->
            <Hyperlink text="← Retour à la connexion"
                       onAction="#goToLogin"
                       style="-fx-text-fill: #2e7d32; -fx-font-size: 14px;" />

        </VBox>
    </center>
</BorderPane>
